{
  "openapi": "3.0.1",
  "info": {
    "title": "InternPortal API",
    "version": "v1"
  },
  "paths": {
    "/api/Applications/submit": {
      "post": {
        "tags": [
          "Applications"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "CvFile",
                  "Department",
                  "EndDate",
                  "Grade",
                  "InternshipType",
                  "PhoneNumber",
                  "StartDate",
                  "University"
                ],
                "type": "object",
                "properties": {
                  "University": {
                    "type": "string"
                  },
                  "Grade": {
                    "$ref": "#/components/schemas/InternPortal.Domain.Enums.StudentGrade"
                  },
                  "Department": {
                    "$ref": "#/components/schemas/InternPortal.Domain.Enums.Department"
                  },
                  "InternshipType": {
                    "$ref": "#/components/schemas/InternPortal.Domain.Enums.InternshipType"
                  },
                  "PhoneNumber": {
                    "pattern": "^5\\d{9}$",
                    "type": "string"
                  },
                  "StartDate": {
                    "type": "string",
                    "format": "date"
                  },
                  "EndDate": {
                    "type": "string",
                    "format": "date"
                  },
                  "Description": {
                    "type": "string"
                  },
                  "CvFile": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "University": {
                  "style": "form"
                },
                "Grade": {
                  "style": "form"
                },
                "Department": {
                  "style": "form"
                },
                "InternshipType": {
                  "style": "form"
                },
                "PhoneNumber": {
                  "style": "form"
                },
                "StartDate": {
                  "style": "form"
                },
                "EndDate": {
                  "style": "form"
                },
                "Description": {
                  "style": "form"
                },
                "CvFile": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
