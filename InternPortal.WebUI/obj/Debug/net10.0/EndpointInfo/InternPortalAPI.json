                    "$ref": "#/components/schemas/InternPortal.Domain.Enums.ApplicationStatus"
                  },
                  "Reference": {
                    "type": "string"
                  },
                  "ReferenceGsm": {
                    "pattern": "^5\\d{9}$",
                    "type": "string"
                  },
                  "ReferenceClosenessStatus": {
                    "type": "string"
                  }
                }
              },
