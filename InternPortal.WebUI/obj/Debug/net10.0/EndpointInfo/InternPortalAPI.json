  },
  "components": {
    "schemas": {
      "InternPortal.Application.Dtos.AssignMentorRequest": {
        "type": "object",
        "properties": {
          "internId": {
            "type": "string",
            "format": "uuid"
          },
          "mentorId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "additionalProperties": false
      },
      "InternPortal.Application.Dtos.CreateUserDto": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "surname": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 8,
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[^\\da-zA-Z]).{8,}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "InternPortal.Application.Dtos.LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "InternPortal.Application.Dtos.SocialAccountDto": {
        "type": "object",
        "properties": {
          "platformName": {
            "type": "string",
            "nullable": true
          },
          "profileUrl": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "InternPortal.Application.Dtos.StaffProfileUpdateDto": {
        "type": "object",
        "properties": {
          "expertise": {
            "type": "string",
            "nullable": true
          },
          "biography": {
            "type": "string",
            "nullable": true
          },
          "maxInternCount": {
            "type": "integer",
            "format": "int32"
          },
          "socialAccounts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InternPortal.Application.Dtos.SocialAccountDto"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "InternPortal.Domain.Enums.ApplicationStatus": {
        "enum": [
          "Pending",
          "Approved",
          "Rejected"
        ],
        "type": "string"
      },
      "InternPortal.Domain.Enums.Department": {
        "enum": [
          "Software",
          "Electronics",
          "Project"
        ],
        "type": "string"
      },
      "InternPortal.Domain.Enums.InternshipType": {
        "enum": [
          "Volundatory",
          "Mandatory",
          "IMEP"
        ],
        "type": "string"
      },
      "InternPortal.Domain.Enums.StudentGrade": {
        "enum": [
          "FirstYear",
          "SecondYear",
          "ThirdYear",
          "ForthYear"
        ],
        "type": "string"
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Please enter only JWT tokens.",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
