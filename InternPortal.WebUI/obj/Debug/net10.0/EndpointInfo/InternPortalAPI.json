                  "style": "form"
                },
                "StartDate": {
                  "style": "form"
                },
                "EndDate": {
                  "style": "form"
                },
                "Description": {
                  "style": "form"
                },
                "CvFile": {
                  "style": "form"
                },
                "TranscriptFile": {
                  "style": "form"
                },
                "CvPath": {
                  "style": "form"
                },
                "TranscriptPath": {
                  "style": "form"
                },
                "Status": {
                  "style": "form"
                },
                "Reference": {
                  "style": "form"
                },
