                    "pattern": "^5\\d{9}$",
                    "type": "string"
                  },
                  "StartDate": {
                    "type": "string",
                    "format": "date"
                  },
                  "EndDate": {
                    "type": "string",
                    "format": "date"
                  },
                  "Description": {
                    "type": "string"
                  },
                  "CvFile": {
                    "type": "string",
                    "format": "binary"
                  },
