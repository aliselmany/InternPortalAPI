{
  "openapi": "3.0.1",
  "info": {
    "title": "InternPortal API",
    "version": "v1"
  },
  "paths": {
    "/api/Applications/submit": {
      "post": {
        "tags": [
          "Applications"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "Id": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "Status": {
                    "type": "string"
                  },
                  "AppliedDate": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "UserId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "SchoolName": {
                    "type": "string"
                  },
                  "Grade": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "SelectedDepartment": {
                    "type": "string"
                  },
                  "PhoneNumber": {
                    "type": "string"
                  },
                  "CvUrl": {
                    "type": "string"
                  },
                  "StartDate": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "EndDate": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "Description": {
                    "type": "string"
                  },
                  "InternshipType": {
                    "$ref": "#/components/schemas/InternshipType"
                  },
                  "cvFile": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "Id": {
                  "style": "form"
                },
                "Status": {
                  "style": "form"
                },
                "AppliedDate": {
                  "style": "form"
                },
                "UserId": {
                  "style": "form"
                },
                "SchoolName": {
                  "style": "form"
                },
                "Grade": {
                  "style": "form"
                },
                "SelectedDepartment": {
                  "style": "form"
                },
                "PhoneNumber": {
                  "style": "form"
                },
                "CvUrl": {
                  "style": "form"
                },
                "StartDate": {
                  "style": "form"
                },
                "EndDate": {
                  "style": "form"
                },
                "Description": {
                  "style": "form"
                },
                "InternshipType": {
                  "style": "form"
                },
                "cvFile": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Applications/my-applications": {
      "get": {
        "tags": [
          "Applications"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Users": {
      "get": {
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Users/register": {
      "post": {
        "tags": [
          "Users"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Users/login": {
      "post": {
        "tags": [
          "Users"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Users/{id}": {
      "delete": {
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateUserDto": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "surname": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 8,
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[^\\da-zA-Z]).{8,}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "InternshipType": {
        "enum": [
          0,
          1,
          2
        ],
        "type": "integer",
        "format": "int32"
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Lütfen sadece JWT token giriniz.",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
}