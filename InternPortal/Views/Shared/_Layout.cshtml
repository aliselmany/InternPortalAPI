<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InternPortal</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-light">

    @if (ViewData["HideNavbar"] == null)
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom shadow-sm mb-3">
                <div class="container-fluid">
                    <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-briefcase-fill me-2"></i>InternPortal
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }

    <div class="@(ViewData["HideNavbar"] != null ? "" : "container")">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @if (ViewData["HideNavbar"] == null)
    {
        <footer class="border-top footer text-muted bg-white py-3 mt-auto">
            <div class="container text-center">
                &copy; 2026 - InternPortal - <a asp-controller="Home" asp-action="Privacy">Gizlilik</a>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        (function () {
        
        window.history.pushState(null, "", window.location.href);

        window.onpopstate = function (event) {
       
        window.history.pushState(null, "", window.location.href);
        };
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>