<!DOCTYPE html>
<html lang="tr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Intern Portal</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="/css/auth-portal.css" />

    <style>
            body {
                background: var(--bg-gradient);
                min-height: 100vh;
                display: flex;
                margin: 0;
                padding: 0;
            }

            .intern-sidebar {
                width: 280px;
                background: var(--card-bg);
                border-right: 1px solid var(--input-border);
                display: flex;
                flex-direction: column;
                position: sticky;
                top: 0;
                height: 100vh;
                padding: 1.5rem;
            }

                .intern-sidebar .logo-area {
                    text-align: center;
                    margin-bottom: 2rem;
                }

                    .intern-sidebar .logo-area img {
                        max-width: 150px;
                    }

            .sidebar-menu {
                list-style: none;
                padding: 0;
                margin: 0;
                flex-grow: 1;
            }

                .sidebar-menu li {
                    margin-bottom: 0.5rem;
                }

                .sidebar-menu a {
                    display: flex;
                    align-items: center;
                    padding: 12px 20px;
                    color: var(--text-muted);
                    text-decoration: none;
                    border-radius: 12px;
                    font-weight: 600;
                    transition: all 0.3s ease;
                }

                    .sidebar-menu a i {
                        margin-right: 15px;
                        font-size: 1.2rem;
                    }

                    .sidebar-menu a:hover, .sidebar-menu a.active {
                        background: var(--input-bg);
                        color: var(--primary-portal, #ffc107); 
                    }

            .sidebar-footer {
                border-top: 1px solid var(--input-border);
                padding-top: 1rem;
            }

            .intern-content {
                flex-grow: 1;
                padding: 2rem 3rem;
                overflow-y: auto;
            }
    </style>
</head>
<body>


    <div class="intern-sidebar">
        <div class="logo-area">
            <img src="/assets/trex-logo-dark.png" alt="Logo" id="authLogo" />
        </div>

        <ul class="sidebar-menu">

            <li>
                <a href="/Intern/Dashboard" class="@(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-house-door"></i> Anasayfa
                </a>
            </li>
            <li>
                <a href="/Intern/Kanban" class="@(ViewData["ActivePage"]?.ToString() == "Kanban" ? "active" : "")">
                    <i class="bi bi-kanban"></i> Kanban Panosu
                </a>
            </li>
        </ul>

        <div class="sidebar-footer">
            <a href="#" onclick="logout()" class="text-danger text-decoration-none fw-bold d-flex align-items-center p-2">
                <i class="bi bi-box-arrow-left me-2 fs-5"></i> Çıkış Yap
            </a>
        </div>
    </div>

    <div class="intern-content">
        @RenderBody()
    </div>

    <script>
            function logout() {
                localStorage.removeItem('token');
                window.location.href = '/Account/Login';
            }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>