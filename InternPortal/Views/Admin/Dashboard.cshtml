@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="tr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yönetim Paneli - InternPortal</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

    <link href="https://cdn.jsdelivr.net/npm/@@sweetalert2/theme-dark@@5/dark.css" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/auth-portal.css" />
    
    <style>
        html, body {
            margin: 0 !important; padding: 0 !important;
            width: 100vw !important; height: 100vh !important;
            overflow-x: hidden !important; zoom: 1 !important;
            background: var(--bg-gradient) !important;
        }

        .admin-nav {
            width: 100% !important; padding: 1rem 3rem;
            display: flex; justify-content: space-between; align-items: center;
            background: var(--card-bg); border-bottom: 1px solid var(--input-border);
        }

        .btn-theme-white {
            background: var(--btn-bg) !important; color: var(--btn-text) !important;
            border: 1px solid var(--input-border); font-weight: 700; border-radius: 12px;
            padding: 8px 25px; transition: 0.2s;
        }

        .content-spread { width: 100% !important; padding: 2rem 3rem !important; }
        
        .table-custom { width: 100% !important; table-layout: fixed; border-collapse: separate; border-spacing: 0 10px; }
        
        .table-custom th { 
            padding: 1rem 1.5rem; 
            color: var(--text-muted); 
            font-size: 0.8rem; 
            text-transform: uppercase; 
            font-weight: 700;
            letter-spacing: 1px;
        }

        .table-custom tbody tr { background-color: var(--card-bg); transition: 0.2s; }
        
        .table-custom td { 
            padding: 1.2rem 1.5rem; 
            border-top: 1px solid var(--input-border); 
            border-bottom: 1px solid var(--input-border); 
            vertical-align: middle;
        }
        
        .table-custom td:first-child { border-left: 1px solid var(--input-border); border-radius: 12px 0 0 12px; }
        .table-custom td:last-child { border-right: 1px solid var(--input-border); border-radius: 0 12px 12px 0; }

        .modal-content { background-color: var(--card-bg) !important; border: 1px solid var(--input-border) !important; border-radius: 28px !important; }
        .modal-body { padding: 2.5rem; max-height: 85vh; overflow-y: auto; }
        .form-view-group { margin-bottom: 1.5rem; }
        .form-view-label { font-size: 0.75rem; font-weight: 800; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px; display: block; }

        .form-view-control { 
            background: var(--input-bg); border: 2px solid var(--input-border); 
            border-radius: 12px; padding: 12px 15px; color: var(--text-main); 
            min-height: 50px; display: flex; align-items: center; width: 100%;
        }
        select.form-view-control { cursor: pointer; appearance: auto; }
        input.form-view-control::placeholder, textarea.form-view-control::placeholder { color: var(--text-muted); opacity: 0.7; }
        .dropdown-menu { border-radius: 12px !important; margin-top: 15px !important; }
        .dropdown-item { font-weight: 500; transition: 0.2s; }
        .dropdown-item:hover, .dropdown-item:focus { background-color: var(--input-bg) !important; color: var(--primary-portal) !important; }

        .pagination .page-link { background-color: var(--input-bg); border-color: var(--input-border); color: var(--text-main); font-weight: 600; }
        .pagination .page-item.active .page-link { background-color: var(--text-muted); border-color: var(--text-muted); color: var(--card-bg); }
        .pagination .page-item.disabled .page-link { background-color: var(--card-bg); color: var(--text-muted); border-color: var(--input-border); opacity: 0.5; }
    </style>
</head>

<body>

  <partial name="_AdminNavbarPartial" />

    <div class="content-spread" id="mainWrapper">
  
        <div class="row mb-4 px-3">
            <div class="col-md-3 mb-2">
                <input type="text" id="filterName" class="form-control form-view-control w-100" placeholder="Stajyer Ara..." onkeyup="applyFilters()">
            </div>
            <div class="col-md-3 mb-2">
                <input type="text" id="filterSchool" class="form-control form-view-control w-100" placeholder="Üniversite Ara..." onkeyup="applyFilters()">
            </div>
            <div class="col-md-2 mb-2">
                <input type="text" id="filterDept" class="form-control form-view-control w-100" placeholder="Bölüm Ara..." onkeyup="applyFilters()">
            </div>
            <div class="col-md-2 mb-2">
                <select id="filterType" class="form-select form-view-control w-100" onchange="applyFilters()">
                    <option value="">Staj Türü (Tümü)</option>
                    <option value="0">Zorunlu</option>
                    <option value="1">Gönüllü</option>
                </select>
            </div>
            <div class="col-md-2 mb-2">
                <select id="filterStatus" class="form-select form-view-control w-100" onchange="applyFilters()">
                    <option value="">Durum (Tümü)</option>
                    <option value="Beklemede">Beklemede</option>
                    <option value="Onaylandı">Onaylandı</option>
                    <option value="Reddedildi">Reddedildi</option>
                </select>
            </div>
        </div>

        <table class="table-custom">
            <thead>
                <tr>
                    <th style="width: 15%" class="text-start">İşlemler</th>
                    <th style="width: 25%" class="text-start">Stajyer</th>
                    <th style="width: 20%" class="text-start">Üniversite</th>
                    <th style="width: 15%" class="text-start">Bölüm</th>
                    <th style="width: 15%" class="text-center">Staj Türü</th>
                    <th style="width: 10%" class="text-center">Durum</th>              
                </tr>
            </thead>
            <tbody id="appBody"></tbody>
        </table>

       
        <div class="d-flex justify-content-between align-items-center mt-3 px-2">
            <span id="totalBadge" class="text-muted fw-light" style="font-size: 0.95rem; letter-spacing: 0.5px;">Toplam 0 Başvuru</span>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0 shadow-sm" id="paginationWrapper">
               
                </ul>
            </nav>
        </div>
    </div>

    <div class="modal fade" id="inspectModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content shadow-lg text-start">
                <div class="modal-header border-0 px-4 pt-4">
                    <h4 class="fw-bold mb-0">Başvuru Formu İncelemesi / Düzenleme</h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-3"><div class="form-view-group"><label class="form-view-label">Ad</label><input type="text" class="form-control form-view-control" id="fDetName" readonly></div></div>
                        <div class="col-md-3"><div class="form-view-group"><label class="form-view-label">Soyad</label><input type="text" class="form-control form-view-control" id="fDetSurname" readonly></div></div>
                        <div class="col-md-6"><div class="form-view-group"><label class="form-view-label">Telefon</label><input type="text" class="form-control form-view-control" id="fDetPhone"></div></div>
                        
                        <div class="col-md-4"><div class="form-view-group"><label class="form-view-label">Eğitim Seviyesi</label><input type="text" class="form-control form-view-control" id="fDetEduLevel"></div></div>
                        <div class="col-md-4"><div class="form-view-group"><label class="form-view-label">Üniversite</label><input type="text" class="form-control form-view-control" id="fDetSchool"></div></div>
                        <div class="col-md-2"><div class="form-view-group"><label class="form-view-label">Bölüm</label><input type="text" class="form-control form-view-control" id="fDetDept"></div></div>
                        <div class="col-md-2"><div class="form-view-group"><label class="form-view-label">Sınıf</label><input type="text" class="form-control form-view-control" id="fDetGrade"></div></div>
                    </div>
                    
                    <div class="row border-top pt-4 mt-2">
                        <div class="col-md-4">
                            <div class="form-view-group">
                                <label class="form-view-label">Hedef Departman</label>
                                <select id="fDetTargetDept" class="form-select form-view-control">
                                    <option value="0">Yazılım</option>
                                    <option value="1">Proje</option>
                                    <option value="2">Elektronik</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-view-group">
                                <label class="form-view-label">Staj Türü</label>
                                <select id="fDetInternType" class="form-select form-view-control">
                                    <option value="0">Zorunlu</option>
                                    <option value="1">Gönüllü</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2"><div class="form-view-group"><label class="form-view-label">Başlangıç Tarihi</label><input type="date" class="form-control form-view-control" id="fDetStartDate"></div></div>
                        <div class="col-md-2"><div class="form-view-group"><label class="form-view-label">Bitiş Tarihi</label><input type="date" class="form-control form-view-control" id="fDetEndDate"></div></div>
                        
                        <div class="col-12"><div class="form-view-group"><label class="form-view-label">Açıklama</label><textarea id="fDetDesc" class="form-control form-view-control" style="min-height: 100px;"></textarea></div></div>
                    </div>

                    <div class="row border-top pt-4 mt-2">
                        <div class="col-md-6">
                            <label class="form-view-label">Referans</label>
                            <div class="d-flex flex-column gap-2 p-3 rounded-4 border">
                                <input type="text" id="fDetRefName" class="form-control form-view-control" placeholder="Referans Adı">
                                <input type="text" id="fDetRefGsm" class="form-control form-view-control" placeholder="Referans Telefon">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-view-label">Dosyalar</label>
                            <div class="d-flex gap-2">
                                <a id="fDetCv" href="#" target="_blank" class="btn btn-theme-white flex-grow-1">CV Görüntüle</a>
                                <a id="fDetTranscript" href="#" target="_blank" class="btn btn-theme-white flex-grow-1">Transkript</a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 gap-3 d-flex" id="modalFooter">
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script>
        const token = localStorage.getItem('token');
        
        if (!token) {
            window.location.href = '/';
        }

        let currentAppId = null;
        let myModal = null;
        let allApplications = [];
        
     
        let filteredApplications = [];
        let currentPage = 1;
        const itemsPerPage = 10;

        let currentUser = {
            name: "Admin",
            surname: "Kullanıcı",
            email: "admin@internportal.com",
            phone: "0555 555 55 55"
        };


        document.addEventListener('DOMContentLoaded', () => {
            if (!localStorage.getItem('token')) {
                window.location.href = '/';
                return;
            }

            const modalElement = document.getElementById('inspectModal');
            if (modalElement) {
                myModal = new bootstrap.Modal(modalElement);
            }

            applyTheme(localStorage.getItem('portal-theme') || 'dark');
            fetchApplications();
        });

        function applyTheme(theme) {
            document.documentElement.setAttribute('data-bs-theme', theme);
            const authLogo = document.getElementById('authLogo');
            const themeIcon = document.getElementById('themeIcon');
            const version = new Date().getTime();
            
            if (theme === 'dark') {
                if(themeIcon) themeIcon.className = 'bi bi-moon-fill';
                if(authLogo) authLogo.src = `/assets/trex-logo-light.png?v=${version}`;
            } else {
                if(themeIcon) themeIcon.className = 'bi bi-sun-fill';
                if(authLogo) authLogo.src = `/assets/trex-logo-dark.png?v=${version}`;
            }
        }

        function toggleTheme() {
            const current = document.documentElement.getAttribute('data-bs-theme');
            const target = current === 'dark' ? 'light' : 'dark';
            localStorage.setItem('portal-theme', target);
            applyTheme(target);
        }
   
        function logout() {
            localStorage.removeItem('token');
            window.location.href = '/'; 
        }

        function showProfile() {
            Swal.fire({
                title: 'Profil Bilgileri',
                html: `
                    <div class="text-start mt-3" style="font-size: 1.1rem;">
                        <div class="mb-2"><strong class="text-muted">Ad Soyad:</strong> <span class="ms-2">${currentUser.name} ${currentUser.surname}</span></div>
                        <div class="mb-2"><strong class="text-muted">E-posta:</strong> <span class="ms-2">${currentUser.email}</span></div>
                        <div class="mb-2"><strong class="text-muted">Telefon:</strong> <span class="ms-2">${currentUser.phone}</span></div>
                        <hr style="border-color: var(--input-border);">
                        <span class="badge bg-secondary px-3 py-2">Sistem Yöneticisi</span>
                    </div>
                `,
                icon: 'info',
                confirmButtonText: 'Kapat',
                confirmButtonColor: '#ffc107',
                background: 'var(--card-bg)',
                color: 'var(--text-main)'
            });
        }

        function showEditProfile() {
            Swal.fire({
                title: 'Profili Düzenle',
                html: `
                    <div class="text-start mt-3">
                        <label class="form-label text-muted small fw-bold">Ad</label>
                        <input id="swal-input-name" class="form-control mb-3" value="${currentUser.name}" style="background: var(--input-bg); color: var(--text-main); border: 1px solid var(--input-border);">
                        
                        <label class="form-label text-muted small fw-bold">Soyad</label>
                        <input id="swal-input-surname" class="form-control mb-3" value="${currentUser.surname}" style="background: var(--input-bg); color: var(--text-main); border: 1px solid var(--input-border);">
                        
                        <label class="form-label text-muted small fw-bold">Telefon</label>
                        <input id="swal-input-phone" class="form-control mb-3" value="${currentUser.phone}" style="background: var(--input-bg); color: var(--text-main); border: 1px solid var(--input-border);">
                    </div>
                `,
                showCancelButton: true,
                confirmButtonText: 'Kaydet',
                cancelButtonText: 'İptal',
                confirmButtonColor: '#198754', 
                cancelButtonColor: '#dc3545',  
                background: 'var(--card-bg)',
                color: 'var(--text-main)',
                preConfirm: () => {
                    return {
                        name: document.getElementById('swal-input-name').value,
                        surname: document.getElementById('swal-input-surname').value,
                        phone: document.getElementById('swal-input-phone').value
                    }
                }
            }).then((result) => {
                if (result.isConfirmed) {        
                    currentUser.name = result.value.name;
                    currentUser.surname = result.value.surname;
                    currentUser.phone = result.value.phone;
                    
                    Swal.fire({
                        title: 'Başarılı!',
                        text: 'Profil bilgileriniz güncellendi.',
                        icon: 'success',
                        background: 'var(--card-bg)',
                        color: 'var(--text-main)',
                        confirmButtonColor: '#ffc107'
                    });
                }
            });
        }

        async function fetchApplications() {
            try {
                const response = await fetch('https://localhost:7166/Applications/api/all', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if (!response.ok) {
                    if (response.status === 401) {
                        logout(); 
                    }
                    return;
                }
                
                allApplications = await response.json();
                applyFilters(); 
            } catch (err) { console.error(err); }
        }

        function applyFilters() {
            const fName = document.getElementById('filterName').value.toLowerCase();
            const fSchool = document.getElementById('filterSchool').value.toLowerCase();
            const fDept = document.getElementById('filterDept').value.toLowerCase();
            const fType = document.getElementById('filterType').value;
            const fStatus = document.getElementById('filterStatus').value.toLowerCase();

            filteredApplications = allApplications.filter(app => {
                const fullName = `${app.name} ${app.surname}`.toLowerCase();
                const school = (app.schoolName || '').toLowerCase();
                const dept = (app.departmentOfStudy || '').toLowerCase();
                
                const typeVal = app.internshipType === 0 ? "0" : "1";
                const statusVal = (app.status || 'beklemede').toLowerCase();

                const matchName = fullName.includes(fName);
                const matchSchool = school.includes(fSchool);
                const matchDept = dept.includes(fDept);
                const matchType = fType === "" || typeVal === fType;
                const matchStatus = fStatus === "" || statusVal === fStatus;

                return matchName && matchSchool && matchDept && matchType && matchStatus;
            });

     
            currentPage = 1;
            renderTable();
        }

        function renderTable() {
            const tbody = document.getElementById('appBody');
            document.getElementById('totalBadge').textContent = `Toplam ${filteredApplications.length} Başvuru`;
            tbody.innerHTML = '';
            
      
            const totalPages = Math.ceil(filteredApplications.length / itemsPerPage);
            if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;

          
            const startIndex = (currentPage - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;
            const pageData = filteredApplications.slice(startIndex, endIndex);

            pageData.forEach(app => {
                const appId = app.id || app.Id; 
                const typeText = app.internshipType === 0 ? 'Zorunlu' : 'Gönüllü';
                const statusText = app.status || 'Beklemede';
                
                let badgeClass = "bg-warning text-dark";
                if(statusText === "Onaylandı") badgeClass = "bg-success text-white";
                if(statusText === "Reddedildi") badgeClass = "bg-danger text-white";
                
                tbody.insertAdjacentHTML('beforeend', `
                    <tr>
                        <td class="text-start">
                            <button class="btn btn-theme-white shadow-sm w-100" onclick="viewDetails('${appId}')">İncele</button>
                        </td>
                        <td class="fw-bold text-start">${app.name} ${app.surname}</td>
                        <td class="text-start">${app.schoolName || '-'}</td>
                        <td class="text-start">${app.departmentOfStudy || '-'}</td>
                        <td class="text-center">${typeText}</td>
                        <td class="text-center"><span class="badge rounded-pill ${badgeClass} px-3 py-2">${statusText}</span></td>
                    </tr>
                `);
            });

            renderPagination(totalPages);
        }

        function renderPagination(totalPages) {
            const wrapper = document.getElementById('paginationWrapper');
            wrapper.innerHTML = '';

            if (totalPages <= 1) return; 

            let prevDisabled = currentPage === 1 ? 'disabled' : '';
            wrapper.insertAdjacentHTML('beforeend', `<li class="page-item ${prevDisabled}"><a class="page-link" href="#" onclick="changePage(${currentPage - 1}); return false;">&laquo;</a></li>`);

           
            for (let i = 1; i <= totalPages; i++) {
                let activeClass = currentPage === i ? 'active' : '';
                wrapper.insertAdjacentHTML('beforeend', `<li class="page-item ${activeClass}"><a class="page-link" href="#" onclick="changePage(${i}); return false;">${i}</a></li>`);
            }

         
            let nextDisabled = currentPage === totalPages ? 'disabled' : '';
            wrapper.insertAdjacentHTML('beforeend', `<li class="page-item ${nextDisabled}"><a class="page-link" href="#" onclick="changePage(${currentPage + 1}); return false;">&raquo;</a></li>`);
        }

        function changePage(page) {
            currentPage = page;
            renderTable();
        }
        
        function formatForInput(dateStr) {
            if (!dateStr) return '';
            try {
                return new Date(dateStr).toISOString().split('T')[0];
            } catch(e) { return ''; }
        }

        async function viewDetails(id) {
            if (!id || id === 'undefined') return;
            currentAppId = id;
            
            try {
                const res = await fetch(`https://localhost:7166/Applications/api/${id}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                
                if (res.status === 401) {
                    logout();
                    return;
                }
                
                if (!res.ok) return;
                const app = await res.json();
                
                document.getElementById('fDetName').value = app.name || '';
                document.getElementById('fDetSurname').value = app.surname || '';
                document.getElementById('fDetPhone').value = app.phoneNumber || '';
                document.getElementById('fDetEduLevel').value = app.educationLevel || '';
                document.getElementById('fDetSchool').value = app.schoolName || '';
                document.getElementById('fDetDept').value = app.departmentOfStudy || '';
                document.getElementById('fDetGrade').value = app.grade || '';
                
                document.getElementById('fDetTargetDept').value = app.department || '0';
                document.getElementById('fDetInternType').value = app.internshipType === 0 ? "0" : "1";
                document.getElementById('fDetStartDate').value = formatForInput(app.startDate);
                document.getElementById('fDetEndDate').value = formatForInput(app.endDate);
                document.getElementById('fDetDesc').value = app.description || '';
                
                document.getElementById('fDetRefName').value = app.reference || '';
                document.getElementById('fDetRefGsm').value = app.referenceGsm || '';
                
                const cvBtn = document.getElementById('fDetCv');
                if(app.cvPath) {
                    cvBtn.href = app.cvPath;
                    cvBtn.style.pointerEvents = 'auto';
                    cvBtn.classList.remove('disabled');
                } else {
                    cvBtn.href = '#';
                    cvBtn.style.pointerEvents = 'none';
                    cvBtn.classList.add('disabled');
                }

                const tBtn = document.getElementById('fDetTranscript');
                if(app.transcriptPath) { 
                    tBtn.href = app.transcriptPath; 
                    tBtn.style.display = 'block'; 
                } else { 
                    tBtn.style.display = 'none'; 
                }

                const footer = document.getElementById('modalFooter');
                const currentStatus = (app.status || '').toLowerCase();
                const saveBtnHtml = `<button class="btn btn-primary rounded-pill px-4 fw-bold me-auto" onclick="saveApplicationUpdates()">KAYDET</button>`;

                if (currentStatus === 'onaylandı') {
                    footer.innerHTML = saveBtnHtml + `
                        <button class="btn btn-outline-danger rounded-pill px-5 fw-bold" onclick="updateStatus(2)">REDDET</button>
                        <button class="btn btn-warning rounded-pill px-5 fw-bold text-dark" onclick="updateStatus(0)">BEKLEMEYE AL</button>
                    `;
                } else if (currentStatus === 'reddedildi') {
                    footer.innerHTML = saveBtnHtml + `
                        <button class="btn btn-warning rounded-pill px-5 fw-bold text-dark" onclick="updateStatus(0)">BEKLEMEYE AL</button>
                        <button class="btn btn-success rounded-pill px-5 fw-bold" onclick="updateStatus(1)">ONAYLA</button>
                    `;
                } else {
                    footer.innerHTML = saveBtnHtml + `
                        <button class="btn btn-outline-danger rounded-pill px-5 fw-bold" onclick="updateStatus(2)">REDDET</button>
                        <button class="btn btn-success rounded-pill px-5 fw-bold" onclick="updateStatus(1)">ONAYLA</button>
                    `;
                }

                if(myModal) myModal.show();
            } catch (err) { console.error(err); }
        }

        async function saveApplicationUpdates() {
            if (!currentAppId) return;

            let sDate = document.getElementById('fDetStartDate').value;
            let eDate = document.getElementById('fDetEndDate').value;

            const updateData = {
                name: document.getElementById('fDetName').value || null,
                surname: document.getElementById('fDetSurname').value || null,
                phoneNumber: document.getElementById('fDetPhone').value || null,
                educationLevel: document.getElementById('fDetEduLevel').value || null,
                schoolName: document.getElementById('fDetSchool').value || null,
                departmentOfStudy: document.getElementById('fDetDept').value || null,
                grade: document.getElementById('fDetGrade').value || null,
                department: document.getElementById('fDetTargetDept').value !== "" ? parseInt(document.getElementById('fDetTargetDept').value) : null,
                internshipType: document.getElementById('fDetInternType').value !== "" ? parseInt(document.getElementById('fDetInternType').value) : null,
                startDate: sDate ? sDate : null,
                endDate: eDate ? eDate : null,
                description: document.getElementById('fDetDesc').value || null,
                reference: document.getElementById('fDetRefName').value || null,
                referenceGsm: document.getElementById('fDetRefGsm').value || null
            };

            try {
                const res = await fetch(`https://localhost:7166/Applications/update/api/${currentAppId}`, {
                    method: 'PUT',
                    headers: { 
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json' 
                    },
                    body: JSON.stringify(updateData)
                });

                if (res.ok) {
                    Swal.fire({
                        title: 'Başarılı!',
                        text: 'Başvuru bilgileri başarıyla güncellendi.',
                        icon: 'success',
                        background: 'var(--card-bg)',
                        color: 'var(--text-main)'
                    });
                    
                    if (myModal) myModal.hide();
                    fetchApplications(); 
                } else {
                    let errorMsg = "Güncelleme başarısız oldu.";
                    try {
                        const errorData = await res.json();
                        if (errorData.errors) {
                            errorMsg = Object.values(errorData.errors).flat().join('<br>');
                        } else {
                            errorMsg = errorData.message || errorMsg;
                        }
                    } catch(parseErr) {
                        errorMsg = "API tarafında bir sorun oluştu (Girdiğiniz formatları kontrol edin).";
                    }

                    Swal.fire({ 
                        icon: 'warning', 
                        title: 'İşlem Reddedildi', 
                        html: errorMsg, 
                        background: 'var(--card-bg)', 
                        color: 'var(--text-main)' 
                    });
                }
            } catch (e) {
                console.error("Fetch Hatası:", e);
                Swal.fire({ 
                    icon: 'error', 
                    title: 'Bağlantı Hatası', 
                    text: 'Sunucuyla iletişim kurulamadı. API çalışmıyor veya port uyuşmazlığı var.', 
                    background: 'var(--card-bg)', 
                    color: 'var(--text-main)' 
                });
            }
        }
        
        async function updateStatus(statusCode) {
            if (!currentAppId) {
                Swal.fire({ icon: 'error', title: 'Hata', text: 'Geçerli bir başvuru seçilmedi.' });
                return;
            }

            let enumStringValue = "";
            let confirmMessage = "";
            let successColor = "";

            if (statusCode === 1) {
                enumStringValue = "Onaylandı";
                confirmMessage = "Bu başvuruyu ONAYLAMAK istediğinize emin misiniz?";
                successColor = "#198754"; 
            } else if (statusCode === 2) {
                enumStringValue = "Reddedildi";
                confirmMessage = "Bu başvuruyu REDDETMEK istediğinize emin misiniz?";
                successColor = "#dc3545"; 
            } else if (statusCode === 0) {
                enumStringValue = "Beklemede";
                confirmMessage = "Bu başvuruyu BEKLEMEYE ALMAK istediğinize emin misiniz?";
                successColor = "#ffc107"; 
            } else {
                return; 
            }

            Swal.fire({
                title: 'Emin misiniz?',
                text: confirmMessage,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: successColor,
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Evet, Güncelle',
                cancelButtonText: 'İptal',
                background: 'var(--card-bg)',
                color: 'var(--text-main)'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const res = await fetch(`https://localhost:7166/Applications/api/${currentAppId}/status`, {
                            method: 'PUT',
                            headers: { 
                                'Authorization': `Bearer ${token}`,
                                'Content-Type': 'application/json' 
                            },
                            body: JSON.stringify(enumStringValue) 
                        });

                        if (res.ok) {
                            Swal.fire({
                                title: 'Başarılı!',
                                text: `Başvuru durumu '${enumStringValue}' olarak güncellendi.`,
                                icon: 'success',
                                background: 'var(--card-bg)',
                                color: 'var(--text-main)',
                                confirmButtonColor: '#ffc107'
                            });
                            
                            if (myModal) myModal.hide(); 
                            fetchApplications(); 
                            
                        } else {
                            const errorData = await res.json();
                            Swal.fire({ icon: 'error', title: 'Hata', text: errorData.message || 'Güncelleme başarısız oldu.', background: 'var(--card-bg)', color: 'var(--text-main)' });
                        }
                    } catch (err) {
                        Swal.fire({ icon: 'error', title: 'Bağlantı Hatası', text: 'Sunucuya ulaşılamıyor.', background: 'var(--card-bg)', color: 'var(--text-main)' });
                    }
                }
            });
        }
    </script>
</body>
</html>