@{
    ViewData["Title"] = "Başvurum";
    ViewData["HideNavbar"] = true;
}
@model InternPortal.Application.Dtos.ApplicationDto

@section Styles {
    <link rel="stylesheet" href="~/css/auth-portal.css" asp-append-version="true" />
}

<button class="theme-toggle" onclick="toggleTheme()" id="themeBtn" title="Tema Değiştir">
    <i class="bi bi-sun-fill" id="themeIcon"></i>
</button>

<div class="auth-wrapper" style="overflow-y: auto; padding: 2rem 0;">
    <div class="auth-card" id="mainCard" style="width: 900px !important; display: none;">
        
        <div class="d-flex justify-content-between align-items-start mb-5">
            <div>
                <h2 class="fw-bold" style="letter-spacing: -2px; font-size: 2.5rem;">Staj Başvurunuz</h2>
                <p class="text-muted">Başvurunuzun güncel durumunu buradan takip edebilirsiniz.</p>
            </div>
            <span id="statusBadge" class="badge rounded-pill px-4 py-2 fs-6">
            </span>
        </div>

        <div class="row g-5">
            <div class="col-md-6">
                <div class="mb-4">
                    <label class="form-label text-muted small">Üniversite</label>
                    <div class="fw-bold fs-5" id="schoolName">-</div>
                </div>
                <div class="row">
                    <div class="col-6">
                        <label class="form-label text-muted small">Departman</label>
                        <div class="fw-bold" id="department">-</div>
                    </div>
                    <div class="col-6">
                        <label class="form-label text-muted small">Sınıf</label>
                        <div class="fw-bold" id="grade">-</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="mb-4">
                    <label class="form-label text-muted small">Staj Dönemi</label>
                    <div class="fw-bold" id="dateRange">-</div>
                </div>
                <div class="mb-4">
                    <label class="form-label text-muted small">Staj Türü</label>
                    <div class="fw-bold" id="internshipType">-</div>
                </div>
            </div>

            <div class="col-12 mt-0">
                <hr class="opacity-10 mb-4">
                <label class="form-label text-muted small">Açıklama</label>
                <p class="mb-4" id="description">-</p>
                
                <div class="d-flex align-items-center p-3 rounded-4 border border-secondary border-opacity-25 bg-light bg-opacity-10">
                    <i class="bi bi-file-pdf fs-2 me-3"></i>
                    <div class="flex-grow-1">
                        <div class="fw-bold small" id="cvFileName">ozgecmis.pdf</div>
                        <div class="text-muted" style="font-size: 0.7rem;">Sisteme Yüklenen Belge</div>
                    </div>
                    <a href="#" id="cvViewBtn" class="btn btn-sm btn-outline-dark rounded-pill px-3" target="_blank">Görüntüle</a>
                </div>
            </div>
        </div>

        <div class="text-center mt-5">
            <p class="small text-muted mb-0">Başvurunuz incelendikten sonra size e-posta yoluyla bilgi verilecektir.</p>
        </div>
    </div>
</div>
            
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const token = localStorage.getItem('token');
        if (!token) {
        window.location.replace('/Account/Login');
        }

        function applyTheme(theme) {
        const themeBtn = document.getElementById('themeBtn');
        if (!themeBtn) return;
        const themeIcon = document.getElementById('themeIcon');
            
        if (theme === 'dark') {
        document.documentElement.setAttribute('data-bs-theme', 'dark');
        if(themeIcon) themeIcon.className = 'bi bi-moon-fill';
        } else {
        document.documentElement.setAttribute('data-bs-theme', 'light');
        if(themeIcon) themeIcon.className = 'bi bi-sun-fill';
        }
        }

        function toggleTheme() {
        const currentTheme = document.documentElement.getAttribute('data-bs-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        applyTheme(newTheme);
        localStorage.setItem('portal-theme', newTheme);
        }

        async function fetchMyApplication() {
        try {
        const response = await fetch('https://localhost:7166/Applications/api/my-applications', {
        method: 'GET',
        headers: {
        'Authorization': `Bearer ${token}`,
        'Content-Type': 'application/json'
        }
        });

        if (response.ok) {
        const applications = await response.json();
                    
        if (!applications || applications.length === 0) {
        document.getElementById('mainCard').style.display = 'block';
        Swal.fire({
        title: 'Başvuru Bulunamadı',
        text: 'Henüz bir staj başvurunuz bulunmuyor. Forma yönlendiriliyorsunuz.',
        icon: 'info',
        background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#2b3035' : '#fff',
        color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#fff' : '#000'
        }).then(() => {
        window.location.replace('/Applications/Submit');
        });
        return;
        }

        const app = applications[0];

        document.getElementById('schoolName').textContent = app.schoolName || '-';
        document.getElementById('department').textContent = app.department || '-';
        document.getElementById('grade').textContent = app.grade || '-';
        document.getElementById('internshipType').textContent = app.internshipType || '-';
        document.getElementById('description').textContent = app.description || 'Açıklama belirtilmedi.';
                    
        const start = new Date(app.startDate).toLocaleDateString('tr-TR');
        const end = new Date(app.endDate).toLocaleDateString('tr-TR');
        document.getElementById('dateRange').textContent = `${start} - ${end}`;

        if (app.cvPath) {
        document.getElementById('cvViewBtn').href = `https://localhost:7166/${app.cvPath}`;
        const fileName = app.cvPath.split('/').pop() || 'ozgecmis.pdf';
        document.getElementById('cvFileName').textContent = fileName;
        } else {
        document.getElementById('cvViewBtn').style.display = 'none';
        document.getElementById('cvFileName').textContent = 'Dosya Bulunamadı';
        }

        const badge = document.getElementById('statusBadge');
        if (app.status === 'Approved' || app.status === 'Onaylandı') {
        badge.className = 'badge rounded-pill bg-success text-white px-4 py-2 fs-6';
        badge.innerHTML = '<i class="bi bi-check-circle me-2"></i>Onaylandı';
        }
        else if (app.status === 'Rejected' || app.status === 'Reddedildi') {
        badge.className = 'badge rounded-pill bg-danger text-white px-4 py-2 fs-6';
        badge.innerHTML = '<i class="bi bi-x-circle me-2"></i>Reddedildi';
        }
        else {
        badge.className = 'badge rounded-pill bg-warning text-dark px-4 py-2 fs-6';
        badge.innerHTML = '<i class="bi bi-clock-history me-2"></i>Beklemede';
        }

        document.getElementById('mainCard').style.display = 'block';

        } else if (response.status === 401) {
        localStorage.removeItem('token');
        window.location.replace('/Account/Login');
        } else {
        console.error("API Hatası:", response.status);
        document.getElementById('mainCard').style.display = 'block';
        Swal.fire('Hata!', 'Veriler çekilemedi. Hata Kodu: ' + response.status, 'error');
        }
        } catch (error) {
        console.error("Bağlantı Hatası:", error);
        document.getElementById('mainCard').style.display = 'block';
        Swal.fire('Bağlantı Hatası', 'API sunucusuna (7166) ulaşılamıyor.', 'error');
        }
        }

        document.addEventListener('DOMContentLoaded', () => {
        const savedTheme = localStorage.getItem('portal-theme') || 'light';
        applyTheme(savedTheme);
            
        if (token) {
        fetchMyApplication();
        }
        });
    </script>
}