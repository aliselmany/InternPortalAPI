@{
    Layout = null; // Layout'u kesin olarak kırıyoruz
}
<!DOCTYPE html>
<html lang="tr" style="zoom: 0.75 !important; -moz-transform: scale(0.75) !important; -moz-transform-origin: top center !important; height: 100% !important; width: 100% !important;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Başvurum - InternPortal</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://cdn.jsdelivr.net/npm/@@sweetalert2/theme-dark@@5/dark.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth-portal.css" asp-append-version="true" />

    <style>
            /* PROJENİN DİĞER CSS'LERİNİN SAYFAYI BOZMASINI ENGELLİYORUZ */
            html, body {
                margin: 0 !important;
                padding: 0 !important;
                width: 100vw !important;
                height: 100vh !important;
                overflow: hidden !important;
            }

            /* 0.75 ZOOM DEĞERİNE GÖRE DUVARDAN DUVARA KAPLAMA FORMÜLÜ (100 / 0.75 = 133.33) */
            .fixed-navbar-layer {
                position: fixed !important;
                top: 0 !important;
                left: 0 !important;
                width: 133.33vw !important; /* Sağdaki siyah boşluğu YOK EDEN kritik satır */
                height: 85px !important;
                padding: 0 4rem !important;
                display: flex !important;
                justify-content: space-between !important;
                align-items: center !important;
                background-color: var(--card-bg) !important;
                border-bottom: 1px solid var(--input-border) !important;
                z-index: 99999 !important;
                box-sizing: border-box !important;
            }

            /* KARTI EKRANIN TAM ORTASINA ÇİVİLEYEN KATMAN */
            .full-screen-center-layer {
                position: fixed !important;
                top: 0 !important;
                left: 0 !important;
                width: 133.33vw !important;
                height: 133.33vh !important;
                display: flex !important;
                align-items: center !important;
                justify-content: center !important;
                padding-top: 85px !important;
                box-sizing: border-box !important;
                background: var(--bg-gradient) !important;
                z-index: 1000 !important;
            }

            .dropdown-menu {
                background-color: var(--card-bg) !important;
                border-color: var(--input-border) !important;
                border-radius: 12px !important;
                margin-top: 15px !important;
            }
    </style>
</head>
<body>

    <nav class="fixed-navbar-layer shadow-sm">
        <img id="authLogo" src="/assets/trex-logo-light.png" alt="Logo" style="height: 45px !important; width: auto !important; object-fit: contain;" />

        <div class="d-flex align-items-center gap-4">
            <div class="theme-toggle-btn" onclick="toggleTheme()" style="cursor:pointer; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-moon-fill" id="themeIcon" style="font-size: 1.5rem !important; transition: 0.3s;"></i>
            </div>

            <div class="dropdown" style="z-index: 999999 !important;">
                <div class="d-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;">
                    <i class="bi bi-person-circle" id="profileIcon" style="font-size: 2rem !important; transition: 0.3s; color: var(--text-muted);"></i>
                </div>
                <ul class="dropdown-menu dropdown-menu-end shadow">
                    <li><a class="dropdown-item d-flex align-items-center gap-3 py-2 text-primary-portal fw-semibold" href="#" onclick="showProfile()"><i class="bi bi-person fs-5"></i> Profilim</a></li>
                    <li><hr class="dropdown-divider" style="border-color: var(--input-border); opacity: 0.2;"></li>
                    <li><a class="dropdown-item d-flex align-items-center gap-3 py-2 text-danger fw-semibold" href="#" onclick="logout()"><i class="bi bi-box-arrow-right fs-5"></i> Çıkış Yap</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="full-screen-center-layer">
        <div class="auth-card shadow-lg" id="mainCard" style="width: 900px !important; display: none;">

            <div class="d-flex justify-content-between align-items-start mb-5">
                <div>
                    <h2 class="fw-bold" style="letter-spacing: -2px; font-size: 2.5rem;">Staj Başvurunuz</h2>
                    <p class="text-muted">Başvurunuzun güncel durumunu buradan takip edebilirsiniz.</p>
                </div>
                <span id="statusBadge" class="badge rounded-pill px-4 py-2 fs-6"></span>
            </div>

            <div class="row g-5">
                <div class="col-md-6">
                    <div class="mb-4">
                        <label class="form-label text-muted small">Üniversite</label>
                        <div class="fw-bold fs-5" id="schoolName">-</div>
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <label class="form-label text-muted small">Departman</label>
                            <div class="fw-bold" id="department">-</div>
                        </div>
                        <div class="col-6">
                            <label class="form-label text-muted small">Sınıf</label>
                            <div class="fw-bold" id="grade">-</div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="mb-4">
                        <label class="form-label text-muted small">Staj Dönemi</label>
                        <div class="fw-bold" id="dateRange">-</div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted small">Staj Türü</label>
                        <div class="fw-bold" id="internshipType">-</div>
                    </div>
                </div>

                <div class="col-12 mt-0">
                    <hr class="opacity-10 mb-4">
                    <label class="form-label text-muted small">Açıklama</label>
                    <p class="mb-4" id="description">-</p>

                    <div class="d-flex align-items-center p-3 rounded-4 border border-secondary border-opacity-25 bg-light bg-opacity-10">
                        <i class="bi bi-file-pdf fs-2 me-3"></i>
                        <div class="flex-grow-1">
                            <div class="fw-bold small" id="cvFileName">ozgecmis.pdf</div>
                            <div class="text-muted" style="font-size: 0.7rem;">Sisteme Yüklenen Belge</div>
                        </div>
                        <a href="#" id="cvViewBtn" class="btn btn-sm btn-outline-dark rounded-pill px-3" target="_blank">Görüntüle</a>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5">
                <p class="small text-muted mb-0">Başvurunuz incelendikten sonra size e-posta yoluyla bilgi verilecektir.</p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const token = localStorage.getItem('token');
        if (!token) {
        window.location.replace('/Account/Login');
        }

        let currentUser = {
        name: "Yükleniyor...",
        surname: "",
        email: "Yükleniyor...",
        phone: "Yükleniyor..."
        };

        async function fetchUserProfile() {
        try {
        const res = await fetch('https://localhost:7166/api/users/me', {
        headers: { 'Authorization': `Bearer ${token}` }
        });

        if (res.ok) {
        const user = await res.json();
        currentUser.name = user.name || user.Name || "İsimsiz";
        currentUser.surname = user.surname || user.Surname || "";
        currentUser.email = user.email || user.Email || "-";
        currentUser.phone = user.phoneNumber || user.PhoneNumber || user.phone || user.Phone || "-";
        }
        } catch (err) {
        console.error("Profil çekilemedi:", err);
        }
        }

        function showProfile() {
        Swal.fire({
        title: 'Profil Bilgileri',
        html: `
        <div class="text-start mt-3" style="font-size: 1.1rem;">
        <div class="mb-2"><strong class="text-muted">Ad Soyad:</strong> <span class="ms-2">${currentUser.name} ${currentUser.surname}</span></div>
        <div class="mb-2"><strong class="text-muted">E-posta:</strong> <span class="ms-2">${currentUser.email}</span></div>
        <div class="mb-2"><strong class="text-muted">Telefon:</strong> <span class="ms-2">${currentUser.phone}</span></div>
        <hr style="border-color: var(--input-border);">
        <span class="badge bg-secondary px-3 py-2">Stajyer Adayı</span>
        </div>
        `,
        icon: 'info',
        confirmButtonText: 'Kapat',
        confirmButtonColor: '#ffc107',
        background: 'var(--card-bg)',
        color: 'var(--text-main)'
        });
        }

        function logout() {
        localStorage.removeItem('token');
        window.location.href = '/Account/Login';
        }

        // TEMA İŞLEMLERİ
        function applyTheme(theme) {
        const themeIcon = document.getElementById('themeIcon');
        const authLogo = document.getElementById('authLogo');
        const version = new Date().getTime();

        if (theme === 'dark') {
        document.documentElement.setAttribute('data-bs-theme', 'dark');
        if (themeIcon) themeIcon.className = 'bi bi-moon-fill';
        if (authLogo) authLogo.src = `/assets/trex-logo-light.png?v=${version}`;
        } else {
        document.documentElement.setAttribute('data-bs-theme', 'light');
        if (themeIcon) themeIcon.className = 'bi bi-sun-fill';
        if (authLogo) authLogo.src = `/assets/trex-logo-dark.png?v=${version}`;
        }
        }

        function toggleTheme() {
        const currentTheme = document.documentElement.getAttribute('data-bs-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        applyTheme(newTheme);
        localStorage.setItem('portal-theme', newTheme);
        }

        // VERİ ÇEKME FONKSİYONU
        async function fetchMyApplication() {
        try {
        const response = await fetch('https://localhost:7166/Applications/api/my-applications', {
        method: 'GET',
        headers: {
        'Authorization': `Bearer ${token}`,
        'Content-Type': 'application/json'
        }
        });

        if (response.ok) {
        const applications = await response.json();

        if (!applications || applications.length === 0) {
        document.getElementById('mainCard').style.display = 'block';
        Swal.fire({
        title: 'Başvuru Bulunamadı',
        text: 'Henüz bir staj başvurunuz bulunmuyor. Forma yönlendiriliyorsunuz.',
        icon: 'info',
        background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#2b3035' : '#fff',
        color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#fff' : '#000'
        }).then(() => {
        window.location.replace('/Applications/Submit');
        });
        return;
        }

        const app = applications[0];
        const appStatus = (app.status || '').toLowerCase();

        if (appStatus === 'approved' || appStatus === 'onaylandı') {
        window.location.replace('/Applications/InternDashboard');
        return;
        }

        document.getElementById('schoolName').textContent = app.schoolName || '-';
        document.getElementById('department').textContent = app.department || '-';
        document.getElementById('grade').textContent = app.grade || '-';
        document.getElementById('internshipType').textContent = app.internshipType || '-';
        document.getElementById('description').textContent = app.description || 'Açıklama belirtilmedi.';

        const start = new Date(app.startDate).toLocaleDateString('tr-TR');
        const end = new Date(app.endDate).toLocaleDateString('tr-TR');
        document.getElementById('dateRange').textContent = `${start} - ${end}`;

        if (app.cvPath) {
        document.getElementById('cvViewBtn').href = `https://localhost:7166/${app.cvPath}`;
        const fileName = app.cvPath.split('/').pop() || 'ozgecmis.pdf';
        document.getElementById('cvFileName').textContent = fileName;
        } else {
        document.getElementById('cvViewBtn').style.display = 'none';
        document.getElementById('cvFileName').textContent = 'Dosya Bulunamadı';
        }

        const badge = document.getElementById('statusBadge');
        if (appStatus === 'rejected' || appStatus === 'reddedildi') {
        badge.className = 'badge rounded-pill bg-danger text-white px-4 py-2 fs-6';
        badge.innerHTML = '<i class="bi bi-x-circle me-2"></i>Reddedildi';
        }
        else {
        badge.className = 'badge rounded-pill bg-warning text-dark px-4 py-2 fs-6';
        badge.innerHTML = '<i class="bi bi-clock-history me-2"></i>Beklemede';
        }

        document.getElementById('mainCard').style.display = 'block';

        } else if (response.status === 401) {
        localStorage.removeItem('token');
        window.location.replace('/Account/Login');
        } else {
        document.getElementById('mainCard').style.display = 'block';
        Swal.fire('Hata!', 'Veriler çekilemedi.', 'error');
        }
        } catch (error) {
        document.getElementById('mainCard').style.display = 'block';
        Swal.fire('Bağlantı Hatası', 'API sunucusuna ulaşılamıyor.', 'error');
        }
        }

        document.addEventListener('DOMContentLoaded', () => {
        const savedTheme = localStorage.getItem('portal-theme') || 'dark';
        applyTheme(savedTheme);

        if (token) {
        fetchMyApplication();
        fetchUserProfile();
        }
        });
    </script>
</body>
</html>