@{
    ViewData["Title"] = "Stajyer Paneli";
    ViewData["HideNavbar"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/staff-portal.css" asp-append-version="true" />
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

    <style>
        body, html {
            width: 133.33vw !important;
            height: 133.33vh !important;
            overflow: hidden !important;
            margin: 0 !important;
            padding: 0 !important;
            background-color: var(--bg-main) !important;
            max-width: none !important;
            max-height: none !important;
        }

        .navbar, nav {
            width: 100% !important;
            max-width: 100% !important;
        }

        .board-wrapper {
            width: 100% !important;
            height: calc(133.33vh - 85px) !important;
            display: flex !important;
            flex-direction: column !important;
            overflow: hidden !important;
            box-sizing: border-box !important;
        }

        .board-header {
            padding: 2rem 4rem 1rem 4rem !important;
            display: flex !important;
            align-items: center !important;
            gap: 15px !important;
            flex-shrink: 0 !important;
            border-bottom: 1px solid var(--input-border) !important;
            width: 100% !important;
            box-sizing: border-box !important;
        }

            .board-header h4 {
                font-size: 1.4rem !important;
            }

        .kanban-canvas {
            flex-grow: 1 !important;
            display: flex !important;
            flex-direction: row !important;
            flex-wrap: nowrap !important;
            align-items: flex-start !important;
            padding: 2rem 4rem !important;
            gap: 2rem !important;
            overflow-x: auto !important;
            overflow-y: hidden !important;
            width: 100% !important;
            box-sizing: border-box !important;
        }

        .kanban-col {
            min-width: 340px !important;
            max-width: 340px !important;
            border-radius: 12px !important;
            display: flex !important;
            flex-direction: column !important;
            max-height: calc(133.33vh - 280px) !important;
            border-width: 1px !important;
            border-style: solid !important;
            background: var(--card-bg) !important;
            border-color: var(--input-border) !important;
            box-shadow: 0 4px 8px var(--shadow) !important;
            height: auto !important;
            box-sizing: border-box !important;
        }

        .kanban-col-header {
            padding: 1.2rem !important;
            font-size: 1.15rem !important;
            font-weight: bold !important;
            display: flex !important;
            justify-content: space-between !important;
            align-items: center !important;
            flex-shrink: 0 !important;
            color: var(--text-main) !important;
            border-bottom: 1px solid var(--input-border) !important;
        }

            .kanban-col-header i {
                font-size: 1.2rem !important;
            }

        .kanban-cards {
            padding: 0.8rem !important;
            overflow-y: auto !important;
            display: flex !important;
            flex-direction: column !important;
            gap: 0.8rem !important;
            min-height: 40px !important;
        }

            .kanban-cards::-webkit-scrollbar {
                width: 6px;
            }

            .kanban-cards::-webkit-scrollbar-track {
                background: transparent;
            }

            .kanban-cards::-webkit-scrollbar-thumb {
                background-color: var(--input-border);
                border-radius: 10px;
            }

        .kanban-card {
            padding: 1.2rem !important;
            border-radius: 8px !important;
            cursor: grab !important;
            position: relative !important;
            flex-shrink: 0 !important;
            background: var(--input-bg) !important;
            border: 1px solid var(--input-border) !important;
            color: var(--text-main) !important;
            font-size: 1.05rem !important;
            font-weight: 500 !important;
            box-shadow: 0 1px 3px var(--shadow) !important;
            transition: transform 0.2s, border-color 0.2s !important;
        }

            .kanban-card:active {
                cursor: grabbing !important;
            }

            .kanban-card:hover {
                transform: translateY(-2px) !important;
                border-color: var(--text-muted) !important;
                box-shadow: 0 4px 8px var(--shadow) !important;
            }

        [data-bs-theme="dark"] .kanban-col {
            background: #212529 !important;
        }

        [data-bs-theme="dark"] .kanban-card {
            background: #2b3035 !important;
        }

        .modal-backdrop {
            width: 133.33vw !important;
            height: 133.33vh !important;
        }

        .modal {
            width: 133.33vw !important;
            height: 133.33vh !important;
        }

        .custom-task-modal .modal-dialog {
            max-width: 65% !important;
            margin-top: 5rem;
        }

        .custom-task-modal .modal-content {
            background-color: var(--card-bg) !important;
            color: var(--text-main) !important;
            border: 1px solid var(--input-border) !important;
            border-radius: 16px !important;
            box-shadow: 0 15px 35px var(--shadow) !important;
        }

        .custom-task-modal .modal-header {
            border-bottom: 1px solid var(--input-border) !important;
            padding: 1.5rem 2rem !important;
        }

        .custom-task-modal .modal-body {
            padding: 2rem !important;
        }

        [data-bs-theme="dark"] .custom-task-modal .btn-close {
            filter: invert(1) grayscale(100%) brightness(200%);
        }

        .btn-theme-custom {
            background-color: var(--btn-bg) !important;
            color: var(--btn-text) !important;
            border: 1px solid var(--input-border) !important;
        }

            .btn-theme-custom:hover {
                opacity: 0.85;
            }

        .mentor-email-link {
            color: var(--text-main) !important;
            transition: opacity 0.2s ease;
        }

            .mentor-email-link:hover {
                opacity: 0.7;
                text-decoration: underline !important;
            }

        .editor-wrapper {
            border: 2px solid var(--input-border);
            border-radius: 8px;
            background-color: var(--input-bg);
            transition: all 0.2s ease-in-out;
            overflow: hidden;
            margin-bottom: 1.5rem;
        }

            .editor-wrapper:focus-within {
                border-color: #3b82f6;
                box-shadow: 0 0 0 1px #3b82f6;
            }

        .ql-toolbar.ql-snow {
            border: none !important;
            border-bottom: 1px solid var(--input-border) !important;
            padding: 10px 15px !important;
            background-color: transparent;
        }

        .ql-container.ql-snow {
            border: none !important;
            font-size: 1.1rem;
            font-family: inherit;
            color: var(--text-main);
        }

        .ql-editor {
            min-height: 250px;
        }

            .ql-editor a, #taskDescriptionEditor a, .ql-container a {
                color: #3b82f6 !important;
                background-color: rgba(59, 130, 246, 0.15) !important;
                border: 1px solid rgba(59, 130, 246, 0.3) !important;
                padding: 4px 10px !important;
                border-radius: 6px !important;
                text-decoration: none !important;
                font-weight: 600 !important;
                display: inline-flex !important;
                align-items: center !important;
                gap: 6px !important;
                transition: all 0.2s ease-in-out !important;
                margin: 2px 4px !important;
            }

                .ql-editor a::before, #taskDescriptionEditor a::before, .ql-container a::before {
                    content: "🔗" !important;
                    font-size: 0.9rem !important;
                }

                .ql-editor a:hover, #taskDescriptionEditor a:hover, .ql-container a:hover {
                    color: #ffffff !important;
                    background-color: #3b82f6 !important;
                    border-color: #3b82f6 !important;
                    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4) !important;
                    transform: translateY(-1px) !important;
                }

        [data-bs-theme="dark"] .ql-snow .ql-stroke {
            stroke: #adb5bd;
        }

        [data-bs-theme="dark"] .ql-snow .ql-fill {
            fill: #adb5bd;
        }

        [data-bs-theme="dark"] .ql-snow .ql-picker {
            color: #adb5bd;
        }

        [data-bs-theme="dark"] .ql-editor.ql-blank::before {
            color: #6c757d;
            font-style: normal;
        }

        .comments-container::-webkit-scrollbar {
            width: 6px;
        }

        .comments-container::-webkit-scrollbar-track {
            background: transparent;
        }

        .comments-container::-webkit-scrollbar-thumb {
            background-color: var(--input-border);
            border-radius: 10px;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
}

<partial name="_InternNavbarPartial" />

<div class="board-wrapper">

    <div class="board-header">
         <h4 class="m-0 fw-bold"><i class="bi bi-kanban me-2"></i> Çalışma Alanım</h4>
    </div>

    <div class="kanban-canvas" id="kanbanBoard">
        <div class="kanban-col">
            <div class="kanban-col-header"><span>Yapılacaklar</span><i class="bi bi-three-dots"></i></div>
            <div class="kanban-cards" id="ToDo" data-status="ToDo"></div>
        </div>

        <div class="kanban-col">
            <div class="kanban-col-header"><span>Yapılıyor</span><i class="bi bi-three-dots"></i></div>
            <div class="kanban-cards" id="InProgress" data-status="InProgress"></div>
        </div>

        <div class="kanban-col">
            <div class="kanban-col-header"><span>İnceleniyor</span><i class="bi bi-three-dots"></i></div>
            <div class="kanban-cards" id="InReview" data-status="InReview"></div>
        </div>

        <div class="kanban-col">
            <div class="kanban-col-header"><span>Tamamlandı</span><i class="bi bi-three-dots"></i></div>
            <div class="kanban-cards" id="Done" data-status="Done"></div>
        </div>
    </div>

</div>

<div class="modal fade custom-task-modal" id="taskDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header border-0 pb-0 px-4 pt-4 d-flex justify-content-between align-items-center">
                <h3 class="modal-title fw-bold m-0" id="taskDetailModalLabel" style="color: var(--text-main);">
                    <i class="bi bi-card-checklist me-2"></i>Görev Adı
                </h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body px-4 pt-4 pb-4">
                <div class="row h-100">

                    <div class="col-lg-8 border-end pe-4" style="border-color: var(--input-border) !important;">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="text-uppercase text-muted fw-bold m-0" style="letter-spacing: 1px;">
                                <i class="bi bi-justify-left me-2"></i>Açıklama
                            </h5>
                            <span id="taskStatusBadge" class="badge bg-warning text-dark px-4 py-2 fs-6" style="border-radius: 8px;">ToDo</span>
                        </div>

                        <div class="editor-wrapper mb-4">
                            <div id="quillToolbar">
                                <span class="ql-formats">
                                    <button class="ql-bold"></button>
                                    <button class="ql-italic"></button>
                                    <button class="ql-underline"></button>
                                    <button class="ql-strike"></button>
                                </span>
                                <span class="ql-formats">
                                    <button class="ql-list" value="ordered"></button>
                                    <button class="ql-list" value="bullet"></button>
                                </span>
                                <span class="ql-formats">
                                    <button class="ql-link"></button>
                                    <button class="ql-image"></button>
                                    <button class="ql-code-block"></button>
                                </span>
                            </div>
                            <div id="taskDescriptionEditor" style="min-height: 280px;"></div>
                        </div>

                        <div class="d-flex justify-content-end align-items-center">
                            <button type="button" class="btn btn-theme-custom px-5 py-2 fw-bold fs-6 d-flex align-items-center gap-2" onclick="saveTaskDescription()" style="border-radius: 8px;">
                                <i class="bi bi-save"></i> Kaydet
                            </button>
                        </div>
                    </div>

                    <div class="col-lg-4 ps-4 d-flex flex-column" style="max-height: 460px;">
                        <h5 class="text-uppercase text-muted fw-bold m-0 mb-3" style="letter-spacing: 1px;">
                            <i class="bi bi-chat-left-text me-2"></i>Yorumlar
                        </h5>

                        <div class="comments-container flex-grow-1 overflow-auto mb-3 pe-2" id="commentsList">
                            <div class="text-center text-muted mt-5" id="noCommentText" style="font-size: 0.9rem;">
                                <i class="bi bi-chat-square-dots fs-1 mb-2 d-block opacity-50"></i>
                                Henüz yorum yapılmamış.
                            </div>
                        </div>

                        <div class="add-comment-box mt-auto pt-2 border-top" style="border-color: var(--input-border) !important;">
                            <textarea id="newCommentInput" class="form-control mb-2 shadow-none" rows="2" placeholder="Bir yorum yazın..." style="background-color: var(--input-bg); color: var(--text-main); border: 2px solid var(--input-border); border-radius: 8px; resize: none; font-size: 0.95rem;"></textarea>
                            <button class="btn btn-theme-custom w-100 fw-bold py-2" onclick="addComment()" style="border-radius: 8px;">
                                Gönder
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mentorInfoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content shadow-lg" style="background-color: var(--card-bg); color: var(--text-main); border: 1px solid var(--input-border); border-radius: 16px;">
            <div class="modal-header border-0 pb-0 justify-content-end">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" style="filter: invert(1) grayscale(100%) brightness(200%);"></button>
            </div>
            <div class="modal-body text-center px-4 pb-5 pt-0">

                <div class="mb-3">
                    <i class="bi bi-person-bounding-box text-secondary" style="font-size: 5rem;"></i>
                </div>

                <h4 class="fw-bold mb-1" id="mentorNameDisplay">Yükleniyor...</h4>
                <p class="text-muted mb-4" id="mentorExpertiseDisplay" style="font-size: 0.95rem;">Lütfen bekleyin</p>

                <div class="d-flex flex-column gap-3 text-start">
                    <div class="p-3 rounded-3 shadow-sm" style="background-color: var(--input-bg); border: 1px solid var(--input-border);">
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                            <i class="bi bi-envelope-fill me-1"></i> E-Posta Adresi
                        </small>
                        <div class="fs-6 mt-1 fw-medium" id="mentorEmailDisplay">...</div>
                    </div>
                </div>

                <div id="mentorSocialsDisplay" class="d-flex justify-content-center gap-3 mt-4">
                </div>

            </div>
        </div>
    </div>
</div>

<input type="hidden" id="currentOpenTaskId" value="" />

@section Scripts {
    <partial name="_ThemeScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

    <script>
        const API_URL = "https://localhost:7166";
        const token = localStorage.getItem('token');

        let globalTasksData = [];
        let quillEditor;

        if (!token) window.location.replace('/Account/Login');

        function getUserIdFromToken(jwt) {
        try {
        const payload = JSON.parse(atob(jwt.split('.')[1]));
        return payload["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier"];
        } catch (e) {
        return null;
        }
        }

        const currentInternId = getUserIdFromToken(token);
        const isUserStaff = false;

        let currentUser = {
        name: "Yükleniyor...",
        surname: "",
        email: "Yükleniyor...",
        phone: "Yükleniyor..."
        };

        async function fetchUserProfile() {
        if (!currentInternId) return;
        try {
        const res = await fetch(`${API_URL}/api/Users/get-by-id/${currentInternId}`, {
        headers: { 'Authorization': `Bearer ${token}` }
        });

        if (res.ok) {
        const user = await res.json();
        currentUser.name = user.name || user.Name || "İsimsiz";
        currentUser.surname = user.surname || user.Surname || "";
        currentUser.email = user.email || user.Email || "-";
        currentUser.phone = user.phoneNumber || user.PhoneNumber || "-";
        }
        } catch (err) {
        console.error("Profil bilgisi çekilirken hata oluştu:", err);
        }
        }

        window.showProfile = function() {
        const currentTheme = document.documentElement.getAttribute('data-bs-theme');
        const isDark = currentTheme === 'dark';

        Swal.fire({
        title: 'Profil Bilgileri',
        html: `
        <div class="text-start mt-3" style="font-size: 1.1rem;">
        <div class="mb-2"><strong class="text-muted">Ad Soyad:</strong> <span class="ms-2" style="color: var(--text-main);">${currentUser.name} ${currentUser.surname}</span></div>
        <div class="mb-2"><strong class="text-muted">E-posta:</strong> <span class="ms-2" style="color: var(--text-main);">${currentUser.email}</span></div>
        <div class="mb-2"><strong class="text-muted">Telefon:</strong> <span class="ms-2" style="color: var(--text-main);">${currentUser.phone}</span></div>
        <hr style="border-color: var(--input-border);">
        <span class="badge bg-primary px-3 py-2">Stajyer Adayı</span>
        </div>
        `,
        icon: 'info',
        confirmButtonText: 'Kapat',
        confirmButtonColor: '#ffc107',
        background: 'var(--card-bg)',
        color: 'var(--text-main)'
        });
        };

        document.addEventListener('DOMContentLoaded', async () => {
        await checkMentorStatus();
        initSortable();
        loadTasks();
        await fetchUserProfile();

        quillEditor = new Quill('#taskDescriptionEditor', {
        theme: 'snow',
        modules: {
        toolbar: '#quillToolbar'
        },
        placeholder: 'Bu görev için detaylı bir açıklama girin...'
        });
        });

        async function checkMentorStatus() {
        if (!currentInternId) return;

        try {
        const response = await fetch(`${API_URL}/api/Users/get-by-id/${currentInternId}`, {
        headers: { 'Authorization': `Bearer ${token}` }
        });

        if (response.ok) {
        const user = await response.json();

        if (!user.mentorId || user.mentorId === "00000000-0000-0000-0000-000000000000") {
        window.location.replace('/Applications/MentorSelection');
        }
        }
        } catch (error) {
        console.error("Erişim kontrolü başarısız:", error);
        }
        }

        async function loadTasks() {
        if (!currentInternId) return;

        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/intern/${currentInternId}`, {
        headers: { 'Authorization': `Bearer ${token}` }
        });

        if (response.ok) {
        const tasks = await response.json();

        globalTasksData = tasks;

        ['ToDo', 'InProgress', 'InReview', 'Done'].forEach(id => {
        const el = document.getElementById(id);
        if(el) el.innerHTML = '';
        });

        tasks.forEach(task => {
        const deleteBtnHtml = isUserStaff ? `<i class="bi bi-trash3 delete-task-btn" onclick="event.stopPropagation(); deleteTask(${task.id})"></i>` : '';

        const cardHtml = `
        <div class="kanban-card shadow-sm" data-task-id="${task.id}" onclick="openTaskModal(${task.id})">
        ${task.title}
        ${deleteBtnHtml}
        </div>`;

        const targetCol = document.getElementById(task.status);
        if (targetCol) targetCol.insertAdjacentHTML('beforeend', cardHtml);
        });
        }
        } catch (error) {
        console.error("Görev yükleme hatası:", error);
        }
        }

        function initSortable() {
        ['ToDo', 'InProgress', 'InReview', 'Done'].forEach(colId => {
        const el = document.getElementById(colId);
        if (el) {
        new Sortable(el, {
        group: 'kanban',
        animation: 150,
        ghostClass: 'bg-secondary',
        onEnd: function (evt) {
        const taskId = evt.item.getAttribute('data-task-id');
        const newStatus = evt.to.getAttribute('data-status');
        const newOrderIndex = evt.newIndex;

        if (evt.from !== evt.to) {
        updateTaskPosition(taskId, newStatus, newOrderIndex);
        }
        }
        });
        }
        });
        }

        async function updateTaskPosition(taskId, newStatus, newOrderIndex) {
        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/move`, {
        method: 'PUT',
        headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({
        taskId: parseInt(taskId, 10),
        newStatus: newStatus,
        newOrderIndex: newOrderIndex
        })
        });

        if (!response.ok) {
        throw new Error("Sunucu güncellemeyi reddetti.");
        }

        } catch (error) {
        console.error("Taşıma hatası:", error);
        loadTasks();
        }
        }

        async function loadTaskComments(taskId) {
        const commentsList = document.getElementById('commentsList');
        commentsList.innerHTML = '<div class="text-center text-muted mt-5"><div class="spinner-border spinner-border-sm me-2"></div>Yorumlar Yükleniyor...</div>';

        const myUserId = getUserIdFromToken(token);

        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/${taskId}/comments`, {
        headers: { 'Authorization': `Bearer ${token}` }
        });

        if (response.ok) {
        const comments = await response.json();
        commentsList.innerHTML = '';

        if (comments.length === 0) {
        commentsList.innerHTML = `
        <div class="text-center text-muted mt-5" id="noCommentText" style="font-size: 0.9rem;">
        <i class="bi bi-chat-square-dots fs-1 mb-2 d-block opacity-50"></i>
        Henüz yorum yapılmamış.
        </div>`;
        return;
        }

        comments.forEach(c => {
        let deleteButtonHtml = '';
        if (c.userId === myUserId) {
        deleteButtonHtml = `
        <i class="bi bi-trash3 text-muted ms-2"
        style="cursor: pointer; transition: color 0.2s;"
        onmouseover="this.classList.remove('text-muted'); this.classList.add('text-danger');"
        onmouseout="this.classList.remove('text-danger'); this.classList.add('text-muted');"
        onclick="deleteTaskComment(${c.id})"
        title="Yorumu Sil"></i>
        `;
        }

        const commentHtml = `
        <div class="comment-item mb-3 p-3 rounded-3" style="background-color: var(--input-bg); border: 1px solid var(--input-border); animation: fadeIn 0.3s ease;">
        <div class="d-flex justify-content-between align-items-start mb-2">
        <div>
        <strong style="color: var(--text-main); font-size: 0.9rem;">${c.userName}</strong>
        <small class="text-muted ms-2" style="font-size: 0.75rem;">${c.createdAt}</small>
        </div>
        ${deleteButtonHtml}
        </div>
        <p class="m-0" style="color: var(--text-main); font-size: 0.95rem;">${c.text}</p>
        </div>`;
        commentsList.insertAdjacentHTML('beforeend', commentHtml);
        });

        commentsList.scrollTop = commentsList.scrollHeight;
        }
        } catch (error) {
        commentsList.innerHTML = '<div class="text-center text-danger mt-5">Yorumlar yüklenirken bir hata oluştu.</div>';
        }
        }

        function openTaskModal(taskId) {
        const task = globalTasksData.find(t => t.id === taskId);
        if (!task) return;

        document.getElementById('currentOpenTaskId').value = taskId;
        document.getElementById('taskDetailModalLabel').innerHTML = `<i class="bi bi-card-checklist me-2"></i>${task.title}`;

        quillEditor.root.innerHTML = task.description || '';

        const badge = document.getElementById('taskStatusBadge');
        badge.innerText = task.status;
        badge.className = `badge text-dark px-3 py-2 bg-${task.status === 'Done' ? 'success' : 'warning'}`;

        loadTaskComments(taskId);

        const modal = new bootstrap.Modal(document.getElementById('taskDetailModal'));
        modal.show();
        }

        async function saveTaskDescription() {
        const taskId = document.getElementById('currentOpenTaskId').value;
        const newDescription = quillEditor.root.innerHTML.trim();

        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/${taskId}/description`, {
        method: 'PUT',
        headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ description: newDescription })
        });

        if (response.ok) {
        Swal.fire({ icon: 'success', title: 'Açıklama kaydedildi', toast: true, position: 'top-end', showConfirmButton: false, timer: 1500 });
        loadTasks();
        } else {
        Swal.fire('Hata', 'Açıklama kaydedilemedi.', 'error');
        }
        } catch (error) {
        console.error("Kaydetme hatası:", error);
        }
        }

        async function addComment() {
        const taskId = document.getElementById('currentOpenTaskId').value;
        const input = document.getElementById('newCommentInput');
        const commentText = input.value.trim();

        if (!commentText || !taskId) return;

        input.disabled = true;

        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/${taskId}/comments`, {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ text: commentText })
        });

        if (response.ok) {
        const newComment = await response.json();

        const commentsList = document.getElementById('commentsList');
        const noCommentText = document.getElementById('noCommentText');
        if (noCommentText) noCommentText.style.display = 'none';

        const myUserId = getUserIdFromToken(token);
        let deleteButtonHtml = '';
        if (newComment.userId === myUserId) {
        deleteButtonHtml = `
        <i class="bi bi-trash3 text-muted ms-2"
        style="cursor: pointer; transition: color 0.2s;"
        onmouseover="this.classList.remove('text-muted'); this.classList.add('text-danger');"
        onmouseout="this.classList.remove('text-danger'); this.classList.add('text-muted');"
        onclick="deleteTaskComment(${newComment.id})"
        title="Yorumu Sil"></i>
        `;
        }

        const commentHtml = `
        <div class="comment-item mb-3 p-3 rounded-3" style="background-color: var(--input-bg); border: 1px solid var(--input-border); animation: fadeIn 0.3s ease;">
        <div class="d-flex justify-content-between align-items-start mb-2">
        <div>
        <strong style="color: var(--text-main); font-size: 0.9rem;">${newComment.userName}</strong>
        <small class="text-muted ms-2" style="font-size: 0.75rem;">${newComment.createdAt}</small>
        </div>
        ${deleteButtonHtml}
        </div>
        <p class="m-0" style="color: var(--text-main); font-size: 0.95rem;">${newComment.text}</p>
        </div>`;

        commentsList.insertAdjacentHTML('beforeend', commentHtml);
        input.value = '';
        commentsList.scrollTop = commentsList.scrollHeight;
        } else {
        Swal.fire('Hata', 'Yorum gönderilirken bir sorun oluştu.', 'error');
        }
        } catch (error) {
        console.error("Yorum gönderme hatası:", error);
        Swal.fire('Bağlantı Hatası', 'Sunucuya ulaşılamadı.', 'error');
        } finally {
        input.disabled = false;
        input.focus();
        }
        }

        async function deleteTaskComment(commentId) {
        const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';

        const result = await Swal.fire({
        title: 'Yorum Silinecek!',
        text: "Bu yorumu silmek istediğinize emin misiniz?",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Evet, Sil',
        cancelButtonText: 'İptal',
        background: isDark ? '#1e1e1e' : '#fff',
        color: isDark ? '#fff' : '#000',
        customClass: { confirmButton: 'btn btn-danger px-4 me-2', cancelButton: 'btn btn-secondary px-4' },
        buttonsStyling: false
        });

        if (result.isConfirmed) {
        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/comments/${commentId}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` }
        });

        if (response.ok) {
        const currentTaskId = document.getElementById('currentOpenTaskId').value;
        loadTaskComments(currentTaskId);
        } else {
        const err = await response.json();
        Swal.fire('Hata', err.message || 'Yorum silinemedi.', 'error');
        }
        } catch (error) {
        console.error("Yorum silme hatası:", error);
        }
        }
        }

        window.showMentorInfo = async function() {
        const modalElement = document.getElementById('mentorInfoModal');
        if (!modalElement) return;

        const modal = new bootstrap.Modal(modalElement);
        modal.show();

        document.getElementById('mentorNameDisplay').innerText = "Aranıyor...";
        document.getElementById('mentorExpertiseDisplay').innerText = "...";
        document.getElementById('mentorEmailDisplay').innerText = "...";
        document.getElementById('mentorSocialsDisplay').innerHTML = "";

        try {
        if (!currentInternId) return;

        const meRes = await fetch(`${API_URL}/api/Users/get-by-id/${currentInternId}`, {
        headers: { 'Authorization': `Bearer ${token}` }
        });
        const meData = await meRes.json();

        if (!meData.mentorId || meData.mentorId === "00000000-0000-0000-0000-000000000000") {
        document.getElementById('mentorNameDisplay').innerText = "Mentör Atanmamış";
        document.getElementById('mentorExpertiseDisplay').innerText = "Şu an için bir mentörünüz bulunmuyor.";
        document.getElementById('mentorEmailDisplay').innerText = "-";
        return;
        }

        const mentorRes = await fetch(`${API_URL}/api/Users/get-by-id/${meData.mentorId}`, {
        headers: { 'Authorization': `Bearer ${token}` }
        });
        const mentorData = await mentorRes.json();

        document.getElementById('mentorNameDisplay').innerText = `${mentorData.name} ${mentorData.surname}`;
        document.getElementById('mentorExpertiseDisplay').innerText = mentorData.expertise || "Uzmanlık alanı belirtilmemiş";
        document.getElementById('mentorEmailDisplay').innerHTML = `<a href="mailto:${mentorData.email}" class="text-decoration-none fw-bold mentor-email-link" style="letter-spacing: 0.5px;">${mentorData.email}</a>`;

        let socialsHtml = "";
        if (mentorData.socialAccounts && mentorData.socialAccounts.length > 0) {
        mentorData.socialAccounts.forEach(acc => {
        let platform = acc.platformName.toLowerCase();

        if (platform.includes("github")) {
        socialsHtml += `
        <a href="${acc.profileUrl}" target="_blank" class="btn btn-outline-secondary rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
        <i class="bi bi-github fs-5" style="color: var(--text-main);"></i>
        </a>`;
        }

        else if (platform.includes("linkedin")) {
        socialsHtml += `
        <a href="${acc.profileUrl}" target="_blank" class="btn btn-outline-secondary rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
        <i class="bi bi-linkedin fs-5" style="color: var(--text-main);"></i>
        </a>`;
        }
        });
        }

        if (socialsHtml === "") {
        socialsHtml = `<span class="text-muted" style="font-size: 0.85rem;"><i class="bi bi-info-circle me-1"></i>Ekli sosyal medya hesabı bulunamadı.</span>`;
        }

        document.getElementById('mentorSocialsDisplay').innerHTML = socialsHtml;

        } catch (error) {
        console.error("Mentör bilgisi çekilemedi:", error);
        document.getElementById('mentorNameDisplay').innerText = "Bir Hata Oluştu";
        document.getElementById('mentorExpertiseDisplay').innerText = "Bağlantı sorunu.";
        }
        };
    </script>
}