@using InternPortal.Application.Dtos
@model LoginRequest
@{
    ViewData["Title"] = "Giriş Yap";
    ViewData["HideNavbar"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth-portal.css" asp-append-version="true" />
}

<button class="theme-toggle" onclick="toggleTheme()" id="themeBtn" title="Tema Değiştir">
    <i class="bi bi-sun-fill"></i>
</button>

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="text-center mb-5">
            <div class="mb-4">
                <img id="authLogo" src="~/assets/trex-logo-dark.png" alt="Logo" style="max-width: 160px; height: auto;">
            </div>
            <h2 class="fw-bold" style="letter-spacing: -2px; font-size: 3rem;">Tekrar Hoş Geldiniz</h2>
            <p class="text-muted" style="font-size: 1.15rem;">Lütfen kurumsal portal giriş bilgilerinizi kullanın.</p>
        </div>

        <div id="errorMessage" class="text-danger small mb-3 text-center fw-bold"></div>

        <form id="loginForm">
            <div class="mb-4">
                <label asp-for="Email" class="form-label">E-Posta Adresi</label>
                <input asp-for="Email" name="Email" type="email" class="form-control form-control-lg" placeholder="E-Mail" required>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <label asp-for="Password" class="form-label mb-0">Şifre</label>
                    <a asp-action="ForgotPassword" asp-controller="Account" class="small text-decoration-none text-muted fw-bold">Şifremi Unuttum?</a>
                </div>
                <div class="position-relative mt-2">
                    <input asp-for="Password" id="loginPassword" name="Password" type="password" class="form-control form-control-lg pe-5" placeholder="••••••••" required>
                    <i class="bi bi-eye-slash fs-5 text-muted position-absolute" id="togglePasswordIcon" style="top: 50%; right: 15px; transform: translateY(-50%); cursor: pointer; z-index: 10;"></i>
                </div>
            </div>

            <div class="mb-4 form-check">
                <input type="checkbox" class="form-check-input" id="rememberMe" name="RememberMe" value="true">
                <label class="form-check-label small fw-bold text-muted" for="rememberMe">Beni Hatırla</label>
            </div>

            <button type="submit" id="btnSubmit" class="btn-auth">Giriş Yap</button>

            <div class="text-center mt-5">
                <span class="text-muted">Hesabınız yok mu?</span>
                <a asp-action="Register" asp-controller="Account" class="text-primary-portal text-decoration-none ms-1">Şimdi Kayıt Ol</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const API_URL = "https://localhost:7166";

        function applyTheme(theme) {
        const authLogo = document.getElementById('authLogo');
        const themeBtn = document.getElementById('themeBtn');
        if (!themeBtn) return;
        const themeIcon = themeBtn.querySelector('i');
        const version = new Date().getTime();

        if (theme === 'dark') {
        document.documentElement.setAttribute('data-bs-theme', 'dark');
        themeIcon.className = 'bi bi-moon-fill';
        if (authLogo) authLogo.src = `/assets/trex-logo-light.png?v=${version}`;
        } else {
        document.documentElement.setAttribute('data-bs-theme', 'light');
        themeIcon.className = 'bi bi-sun-fill';
        if (authLogo) authLogo.src = `/assets/trex-logo-dark.png?v=${version}`;
        }
        }

        function toggleTheme() {
        const currentTheme = document.documentElement.getAttribute('data-bs-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        applyTheme(newTheme);
        localStorage.setItem('portal-theme', newTheme);
        }

        document.addEventListener('DOMContentLoaded', () => {
        const savedTheme = localStorage.getItem('portal-theme') || 'light';
        applyTheme(savedTheme);
        localStorage.removeItem('token');
        });

        
        document.getElementById('togglePasswordIcon').addEventListener('click', function () {
        const passwordInput = document.getElementById('loginPassword');
        if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        this.classList.replace('bi-eye-slash', 'bi-eye');
        } else {
        passwordInput.type = 'password';
        this.classList.replace('bi-eye', 'bi-eye-slash');
        }
        });

        function showThemedAlert(title, text, icon, timer = null, redirectUrl = null) {
        const currentTheme = document.documentElement.getAttribute('data-bs-theme');
        const isDark = currentTheme === 'dark';

        Swal.fire({
        title: title,
        text: text,
        icon: icon,
        timer: timer,
        showConfirmButton: !timer,
        confirmButtonText: 'Tamam',
        background: isDark ? '#2b3035' : '#ffffff',
        color: isDark ? '#f8f9fa' : '#212529',
        confirmButtonColor: isDark ? '#0d6efd' : '#000000'
        }).then(() => {
        if (redirectUrl) {
        window.location.href = redirectUrl;
        }
        });
        }

        document.getElementById('loginForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        const btn = document.getElementById('btnSubmit');
        const errorDiv = document.getElementById('errorMessage');
        const formData = new FormData(this);
        const data = Object.fromEntries(formData.entries());
        data.RememberMe = formData.get('RememberMe') === 'on' || formData.get('RememberMe') === 'true';

        btn.disabled = true;
        btn.textContent = "Giriş Yapılıyor...";
        errorDiv.textContent = "";

        try {
        const response = await fetch(`${API_URL}/api/Users/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
        });

        const result = await response.json();

        if (response.ok) {
        const token = result.token;
        localStorage.setItem('token', token);

        const payload = JSON.parse(atob(token.split('.')[1]));
        const userRole = payload['http://schemas.microsoft.com/ws/2008/06/identity/claims/role'] || payload.role || payload.Role;
        const userId = payload['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier'] || payload.nameid;

        let redirectTarget = '/Home/Index';

        if (userRole === 'Admin') {
        redirectTarget = '/Admin/Dashboard';
        } else if (userRole === 'Staff') {
        redirectTarget = '/Staff/StaffDashboardIndex';
        } else if (userRole === 'Intern') {
        try {
        const [userRes, appRes] = await Promise.all([
        fetch(`${API_URL}/api/Users/get-by-id/${userId}`, { headers: { 'Authorization': `Bearer ${token}` } }),
        fetch(`${API_URL}/Applications/api/my-applications`, { headers: { 'Authorization': `Bearer ${token}` } })
        ]);

        const userData = await userRes.json();
        const appsRaw = await appRes.json();

        let appList = [];
        if (Array.isArray(appsRaw)) appList = appsRaw;
        else if (appsRaw && Array.isArray(appsRaw.$values)) appList = appsRaw.$values;
        else if (appsRaw && Array.isArray(appsRaw.data)) appList = appsRaw.data;

        if (userData.mentorId && userData.mentorId !== "00000000-0000-0000-0000-000000000000") {
        redirectTarget = '/Applications/InternDashboard';
        } else {
        if (appList.length === 0) { 
        redirectTarget = '/Applications/Submit';
        } else {
        const latestApp = appList[0];
        const st = latestApp.status;

        if (st === 0 || st === "Pending" || st === "Beklemede") {
        redirectTarget = '/Applications/MyApplication';
        } else if (st === 1 || st === 2 || st === "Approved" || st === "Onaylandı") {
        redirectTarget = '/Applications/MentorSelection';
        } else {
        redirectTarget = '/Applications/Submit';
        }
        }
        }
        } catch (stajyerErr) {
        console.error("Stajyer akış hatası:", stajyerErr);
        redirectTarget = '/Applications/InternDashboard';
        }
        }

        showThemedAlert('Başarılı!', 'Yönlendiriliyorsunuz...', 'success', 1500, redirectTarget);

        } else {
        showThemedAlert('Hata!', result.message || 'Giriş başarısız.', 'error');
        }

        } catch (error) {
        showThemedAlert('Bağlantı Hatası!', 'Sunucuya bağlanılamadı.', 'error');
        } finally {
        btn.disabled = false;
        btn.textContent = "Giriş Yap";
        }
        });
    </script>
}