@model RegisterViewModel
@{
    ViewData["Title"] = "Kayıt Ol";
    ViewData["HideNavbar"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth-portal.css" asp-append-version="true" />
}

<button class="theme-toggle" onclick="toggleTheme()" id="themeBtn" title="Tema Değiştir">
    <i class="bi bi-sun-fill"></i>
</button>

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="text-center mb-5">
            <div class="mb-4">
                <img id="authLogo" src="~/assets/trex-logo-dark.png" alt="Logo" style="max-width: 160px; height: auto;">
            </div>
            
            <h2 class="fw-bold" style="letter-spacing: -2px; font-size: 3rem;">Aramıza Katılın</h2>
            <p class="text-muted" style="font-size: 1.15rem;">Staj başvurunuzu başlatmak için kurumsal hesabınızı oluşturun.</p>
        </div>

        <div id="errorMessage" class="text-danger small mb-3 text-center fw-bold"></div>

        <form id="registerForm">
            <div class="row g-4">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label">Ad</label>
                    <input asp-for="Name" name="Name" class="form-control form-control-lg" placeholder="Ali Selman" required>
                </div>
                <div class="col-md-6">
                    <label asp-for="Surname" class="form-label">Soyad</label>
                    <input asp-for="Surname" name="Surname" class="form-control form-control-lg" placeholder="Yılmaz" required>
                </div>
            </div>

            <div class="mt-4">
                <label asp-for="Email" class="form-label">E-Posta Adresi</label>
                <input asp-for="Email" name="Email" type="email" class="form-control form-control-lg" placeholder="E-Mail" required>
            </div>

            <div class="mt-4">
                <label asp-for="Password" class="form-label">Şifre</label>
                <input asp-for="Password" name="Password" type="password" class="form-control form-control-lg" placeholder="••••••••" required>
            </div>

            <button type="submit" id="btnSubmit" class="btn-auth">Hesap Oluştur</button>

            <div class="text-center mt-4">
                <span class="text-muted">Zaten hesabınız var mı?</span>
                <a asp-action="Login" class="text-primary-portal text-decoration-none ms-1">Giriş Yap</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function applyTheme(theme) {
        const themeBtn = document.getElementById('themeBtn');
        const themeIcon = themeBtn ? themeBtn.querySelector('i') : null;
        const authLogo = document.getElementById('authLogo');
        const version = new Date().getTime();

        document.documentElement.setAttribute('data-bs-theme', theme);

        if (theme === 'dark') {
        if (themeIcon) themeIcon.className = 'bi bi-moon-fill';
        if (authLogo) authLogo.src = '/assets/trex-logo-light.png?v=' + version;
        } else {
        if (themeIcon) themeIcon.className = 'bi bi-sun-fill';
        if (authLogo) authLogo.src = '/assets/trex-logo-dark.png?v=' + version;
        }
        }

        function toggleTheme() {
        const currentTheme = document.documentElement.getAttribute('data-bs-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        applyTheme(newTheme);
        localStorage.setItem('portal-theme', newTheme);
        }

        document.addEventListener('DOMContentLoaded', () => {
        const savedTheme = localStorage.getItem('portal-theme') || 'light';
        applyTheme(savedTheme);
        });

        function showThemedAlert(title, text, icon, timer = null, redirectUrl = null) {
        const currentTheme = document.documentElement.getAttribute('data-bs-theme');
        const isDark = currentTheme === 'dark';

        Swal.fire({
        title: title,
        text: text,
        icon: icon,
        timer: timer,
        showConfirmButton: !timer,
        confirmButtonText: 'Tamam',
        background: isDark ? '#2b3035' : '#ffffff',
        color: isDark ? '#f8f9fa' : '#212529',
        confirmButtonColor: isDark ? '#0d6efd' : '#000000'
        }).then(() => {
        if (redirectUrl) {
        window.location.href = redirectUrl;
        }
        });
        }

        document.getElementById('registerForm').addEventListener('submit', async function (e) {
        e.preventDefault();

        const btn = document.getElementById('btnSubmit');
        const formData = new FormData(this);
        const data = Object.fromEntries(formData.entries());

        btn.disabled = true;
        btn.textContent = "İşleniyor...";

        try {
        const response = await fetch('https://localhost:7166/api/Users/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
        });

        if (response.ok) {
        this.reset();
                
        showThemedAlert(
        'Başarıyla Kayıt Oldunuz!',
        'Hesabınız aktif edildi. Şimdi giriş yapabilirsiniz.',
        'success',
        2500,
        '/Account/Login'
        );
        } else {
        const result = await response.json();
        showThemedAlert(
        'Kayıt Başarısız',
        result.message || 'Kayıt sırasında bir hata oluştu.',
        'error'
        );
        }
        } catch (error) {
        console.error("Bağlantı Hatası:", error);
        showThemedAlert(
        'Bağlantı Hatası',
        'Sunucuya ulaşılamıyor (Port: 7166).',
        'warning'
        );
        } finally {
        btn.disabled = false;
        btn.textContent = "Hesap Oluştur";
        }
        });
    </script>
}