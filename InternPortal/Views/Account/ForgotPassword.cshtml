@{
    ViewData["Title"] = "Şifremi Unuttum";
    ViewData["HideNavbar"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth-portal.css" asp-append-version="true" />
}

<button class="theme-toggle" onclick="toggleTheme()" id="themeBtn" title="Tema Değiştir">
    <i class="bi bi-sun-fill"></i>
</button>

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="text-center mb-5">
            <div class="mb-4">
                <img id="authLogo" src="~/assets/trex-logo-dark.png" alt="Logo" style="max-width: 160px; height: auto;">
            </div>
            <h2 class="fw-bold" style="letter-spacing: -2px; font-size: 3rem;">Şifremi Unuttum</h2>
            <p class="text-muted" style="font-size: 1.15rem;">Lütfen hesabınıza kayıtlı e-posta adresinizi girin.<br>Size 6 haneli bir onay kodu göndereceğiz.</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div id="errorMessage" class="text-danger small mb-3 text-center fw-bold">@ViewBag.Error</div>
        }

        <form asp-action="ForgotPassword" asp-controller="Account" method="post">
            <div class="mb-4">
                <label class="form-label">E-Posta Adresi</label>
                <input name="email" type="email" class="form-control form-control-lg" placeholder="E-Mail" required>
            </div>

            <button type="submit" id="btnSubmit" class="btn-auth">Kod Gönder</button>

            <div class="text-center mt-5">
                <span class="text-muted">Şifrenizi hatırladınız mı?</span>
                <a asp-action="Login" asp-controller="Account" class="text-primary-portal text-decoration-none ms-1">Giriş Yap</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function applyTheme(theme) {
            const authLogo = document.getElementById('authLogo');
            const themeBtn = document.getElementById('themeBtn');
            if (!themeBtn) return;
            const themeIcon = themeBtn.querySelector('i');
            const version = new Date().getTime();

            if (theme === 'dark') {
                document.documentElement.setAttribute('data-bs-theme', 'dark');
                themeIcon.className = 'bi bi-moon-fill';
                if (authLogo) authLogo.src = `/assets/trex-logo-light.png?v=${version}`;
            } else {
                document.documentElement.setAttribute('data-bs-theme', 'light');
                themeIcon.className = 'bi bi-sun-fill';
                if (authLogo) authLogo.src = `/assets/trex-logo-dark.png?v=${version}`;
            }
        }

        function toggleTheme() {
            const currentTheme = document.documentElement.getAttribute('data-bs-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            applyTheme(newTheme);
            localStorage.setItem('portal-theme', newTheme);
        }

        document.addEventListener('DOMContentLoaded', () => {
            const savedTheme = localStorage.getItem('portal-theme') || 'light';
            applyTheme(savedTheme);
        });
    </script>
}