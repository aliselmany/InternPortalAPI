                                <i class="bi bi-chat-square-dots fs-1 mb-2 d-block opacity-50"></i>
                                Henüz yorum yapılmamış.
                            </div>
                        </div>

                        <div class="add-comment-box mt-auto pt-2 border-top" style="border-color: var(--input-border) !important;">
                            <textarea id="newCommentInput" class="form-control mb-2 shadow-none" rows="2" placeholder="Bir yorum yazın..." style="background-color: var(--input-bg); color: var(--text-main); border: 2px solid var(--input-border); border-radius: 8px; resize: none; font-size: 0.95rem;"></textarea>
                            <button class="btn btn-theme-custom w-100 fw-bold py-2" onclick="addComment()" style="border-radius: 8px;">
                                Gönder
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade custom-task-modal" id="transferModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog" style="max-width: 45% !important; margin-top: 5rem;">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title fw-bold m-0" style="color: var(--text-main);">
                    <i class="bi bi-arrow-left-right me-2"></i>Stajyeri Başka Mentöre Devret
                </h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="fs-5 text-muted mb-4">Seçili stajyeri kendi sorumluluğunuzdan çıkarıp başka bir personele (mentöre) devretmek için admin onayına bir talep gönderin.</p>

                <div class="mb-4">
                    <label class="form-label text-muted fw-bold text-uppercase mb-2" style="letter-spacing: 1px;">Yeni Mentör Seçin:</label>
                    <select id="mentorSelect" class="form-select shadow-sm" style="padding: 1rem !important; font-size: 1rem !important; background-color: var(--input-bg); color: var(--text-main); border: 2px solid var(--input-border); border-radius: 12px;">
                        <option value="">Yükleniyor...</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted fw-bold text-uppercase mb-2" style="letter-spacing: 1px;">Devir Sebebi (Opsiyonel):</label>
                    <textarea id="transferReasonInput" class="form-control shadow-sm" rows="3" placeholder="Lütfen bu devir işleminin nedenini admin için kısaca açıklayın..." style="padding: 1rem !important; font-size: 1rem !important; background-color: var(--input-bg); color: var(--text-main); border: 2px solid var(--input-border); border-radius: 12px; resize: none;"></textarea>
                </div>

                <div class="d-flex justify-content-end mt-2">
                    <button class="btn btn-theme-custom px-5 py-3 fw-bold fs-5 rounded-3" onclick="executeTransfer()">
                        Talep Gönder
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="currentOpenTaskId" value="" />

@section Scripts {
    <partial name="_ThemeScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

    <script>
        const token = localStorage.getItem('token');
        if (!token) window.location.replace('/Account/Login');

        const API_URL = "https://localhost:7166";

        let globalTasksData = [];
        let globalInternsList = [];
        let quillEditor;

        function getUserIdFromToken(jwt) {
        try {
        const payload = JSON.parse(atob(jwt.split('.')[1]));
        return payload["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier"];
        } catch (e) { return null; }
        }

        const currentStaffId = getUserIdFromToken(token);
        const urlParams = new URLSearchParams(window.location.search);
        let currentInternId = urlParams.get('internId');

        document.addEventListener('DOMContentLoaded', () => {
        initSortable();
        loadInternData();

        quillEditor = new Quill('#taskDescriptionEditor', {
        theme: 'snow',
        modules: {
        toolbar: '#quillToolbar'
        },
        placeholder: 'Bu görev için detaylı bir açıklama girin...'
        });
        });

        document.addEventListener('click', function(e) {
        if (e.target && e.target.classList.contains('delete-task-btn')) {
        e.stopPropagation(); 
        const taskId = e.target.getAttribute('data-delete-id');
        if (taskId) {
        deleteTask(taskId);
        }
        }
        });

        async function loadInternData() {
        if (!currentStaffId) return;

        try {
        const response = await fetch(`${API_URL}/api/Users/my-interns/${currentStaffId}`, {
        headers: { 'Authorization': `Bearer ${token}` }
        });

        if (response.ok) {
        const interns = await response.json();
        globalInternsList = interns;
        const navDisplay = document.getElementById('navbarInternNameDisplay');

        if (interns.length === 0) {
        if(navDisplay) navDisplay.innerHTML = `<i class="bi bi-person-workspace text-secondary me-2"></i> Stajyer Bulunmuyor`;
        return;
        }

        if (!currentInternId && interns.length > 0) {
        currentInternId = interns[0].id;
        }

        const activeIntern = interns.find(i => i.id === currentInternId);
        if (activeIntern && navDisplay) {
        const displayName = activeIntern.fullName || (activeIntern.name + " " + activeIntern.surname);
        navDisplay.innerHTML = `<i class="bi bi-person-workspace text-secondary me-2"></i> ${displayName} <span class="text-muted fw-normal ms-1" style="font-size: 0.9rem;">(Çalışma Alanı)</span>`;
        }

        if (currentInternId) loadTasks();
        }
        } catch (error) { console.error("Stajyer bilgileri yüklenemedi:", error); }
        }

        window.openTransferModal = async function() {
        if (!currentInternId) return;

        const modal = new bootstrap.Modal(document.getElementById('transferModal'));
        modal.show();

        const select = document.getElementById('mentorSelect');
        select.innerHTML = '<option value="">Mentörler aranıyor...</option>';
        document.getElementById('transferReasonInput').value = ''; 

        try {
        const response = await fetch(`${API_URL}/api/Users/available-mentors`, {
        headers: { 'Authorization': `Bearer ${token}` }
        });

        if (response.ok) {
        const mentors = await response.json();
        select.innerHTML = '<option value="">Listeden bir mentör seçin...</option>';
        mentors.forEach(m => {
        if(m.id !== currentStaffId) {
        select.innerHTML += `<option value="${m.id}">${m.fullName} (Doluluk: ${m.currentCount}/${m.maxCapacity})</option>`;
        }
        });
        } else {
        select.innerHTML = '<option value="">Mentör listesi çekilemedi.</option>';
        }
        } catch (error) {
        select.innerHTML = '<option value="">Bir hata oluştu.</option>';
        }
        }

        async function executeTransfer() {
        const mentorId = document.getElementById('mentorSelect').value;
        const reasonText = document.getElementById('transferReasonInput').value.trim();

        if (!mentorId) {
        Swal.fire('Eksik Seçim', 'Lütfen devredeceğiniz personeli seçin.', 'warning');
        return;
        }

        const activeIntern = globalInternsList.find(i => i.id === currentInternId);
        const internName = activeIntern ? (activeIntern.fullName || activeIntern.name + " " + activeIntern.surname) : "Seçili Stajyer";
        const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';

        const result = await Swal.fire({
        title: 'Emin misiniz?',
        text: `${internName} isimli stajyer için devir talebi oluşturulacak ve admin onayına sunulacaktır.`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Evet, Talebi Gönder',
        cancelButtonText: 'İptal',
        background: isDark ? '#1e1e1e' : '#fff',
        color: isDark ? '#fff' : '#000',
        customClass: {
        confirmButton: 'btn btn-theme-custom px-4 me-2',
        cancelButton: 'btn btn-secondary px-4'
        },
        buttonsStyling: false
        });

        if (result.isConfirmed) {
        try {
        const response = await fetch(`${API_URL}/api/InternTransfers/request-transfer`, {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({
        internId: currentInternId,
        toStaffId: mentorId,
        reason: reasonText
        })
        });

        if (response.ok) {
        const modalInstance = bootstrap.Modal.getInstance(document.getElementById('transferModal'));
        if (modalInstance) modalInstance.hide();

        Swal.fire({
        icon: 'success',
        title: 'Talep Gönderildi',
        text: 'Devir talebiniz başarıyla oluşturuldu. Admin onayından sonra devir işlemi gerçekleşecektir.',
        confirmButtonColor: '#ffc107'
        });
    
        document.getElementById('transferReasonInput').value = '';
        loadTasks();

        } else {
        const err = await response.json();
        Swal.fire('Hata', err.message || 'Devir talebi oluşturulamadı.', 'error');
        }
        } catch (error) {
        console.error(error);
        Swal.fire('Hata', 'Sunucuya bağlanırken teknik bir sorun oluştu.', 'error');
        }
        }
        }

        async function loadTasks() {
        if (!currentInternId) return;
        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/intern/${currentInternId}`, {
        headers: { 'Authorization': `Bearer ${token}` }
        });

        if (response.ok) {
        const tasks = await response.json();
        globalTasksData = tasks;

        ['ToDo', 'InProgress', 'InReview', 'Done'].forEach(id => document.getElementById(id).innerHTML = '');

        tasks.forEach(task => {
        const cardHtml = `
        <div class="kanban-card shadow-sm" data-task-id="${task.id}" onclick="openTaskModal(${task.id})">
        ${task.title}
        <i class="bi bi-trash3 delete-task-btn" data-delete-id="${task.id}"></i>
        </div>`;
        document.getElementById(task.status).insertAdjacentHTML('beforeend', cardHtml);
        });
        }
        } catch (error) { console.error("Görev yükleme hatası:", error); }
        }

        function showAddCardForm(status) {
        document.getElementById(`addBtn-${status}`).style.display = 'none';
        document.getElementById(`addForm-${status}`).style.display = 'block';
        const inputElement = document.getElementById(`input-${status}`);
        inputElement.focus();
        inputElement.onkeydown = function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        submitNewTask(status);
        }
        };
        }

        function hideAddCardForm(status) {
        document.getElementById(`addForm-${status}`).style.display = 'none';
        document.getElementById(`input-${status}`).value = '';
        document.getElementById(`addBtn-${status}`).style.display = 'block';
        }

        async function submitNewTask(status) {
        if (!currentInternId || !currentStaffId) return;
        const inputElement = document.getElementById(`input-${status}`);
        const taskTitle = inputElement.value.trim();
        if (!taskTitle) { inputElement.focus(); return; }

        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify({ title: taskTitle, internId: currentInternId, staffId: currentStaffId, status: status })
        });

        if (response.ok) {
        hideAddCardForm(status);
        loadTasks();
        } else {
        const err = await response.json();
        Swal.fire('Hata', err.message || 'Görev eklenirken bir sorun oluştu.', 'error');
        }
        } catch (error) { console.error("Ekleme hatası:", error); }
        }

        async function deleteTask(taskId) {
        const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
        const result = await Swal.fire({
        title: 'Silinsin mi?',
        text: "Bu görev kalıcı olarak silinecek!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Sil',
        cancelButtonText: 'Vazgeç',
        background: isDark ? '#1e1e1e' : '#fff',
        color: isDark ? '#fff' : '#000',
        customClass: { confirmButton: 'btn btn-danger px-4 me-2', cancelButton: 'btn btn-secondary px-4' },
        buttonsStyling: false
        });

        if (result.isConfirmed) {
        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/${taskId}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` }
        });
        if (response.ok) {
        loadTasks();
        Swal.fire({ icon: 'success', title: 'Silindi', toast: true, position: 'top-end', showConfirmButton: false, timer: 1500 });
        }
        } catch (error) { console.error("Silme hatası:", error); }
        }
        }

        async function deleteTaskFromModal() {
        const taskId = document.getElementById('currentOpenTaskId').value;
        if (!taskId) return;

        const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
        const result = await Swal.fire({
        title: 'Görev Silinecek!',
        text: "Bu işlem geri alınamaz. Onaylıyor musunuz?",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Evet, Sil',
        cancelButtonText: 'İptal',
        background: isDark ? '#1e1e1e' : '#fff',
        color: isDark ? '#fff' : '#000',
        customClass: { confirmButton: 'btn btn-danger px-4 me-2', cancelButton: 'btn btn-secondary px-4' },
        buttonsStyling: false
        });

        if (result.isConfirmed) {
        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/${taskId}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` }
        });
        if (response.ok) {
        const myModalEl = document.getElementById('taskDetailModal');
        const modal = bootstrap.Modal.getInstance(myModalEl);
        modal.hide();

        loadTasks();
        Swal.fire({ icon: 'success', title: 'Görev başarıyla silindi', toast: true, position: 'top-end', showConfirmButton: false, timer: 1500 });
        }
        } catch (error) { console.error("Silme hatası:", error); }
        }
        }

        function initSortable() {
        ['ToDo', 'InProgress', 'InReview', 'Done'].forEach(colId => {
        const el = document.getElementById(colId);
        if (el) {
        new Sortable(el, {
        group: 'kanban',
        animation: 150,
        ghostClass: 'bg-secondary',
        onEnd: function (evt) {
        const taskId = evt.item.getAttribute('data-task-id');
        const newStatus = evt.to.getAttribute('data-status');
        const newOrderIndex = evt.newIndex;
        updateTaskPosition(taskId, newStatus, newOrderIndex);
        }
        });
        }
        });
        }

        async function updateTaskPosition(taskId, newStatus, newOrderIndex) {
        try {
        await fetch(`${API_URL}/api/KanbanTasks/move`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify({ taskId: parseInt(taskId), newStatus, newOrderIndex })
        });
        } catch (error) { loadTasks(); }
        }

        async function loadTaskComments(taskId) {
        const commentsList = document.getElementById('commentsList');
        commentsList.innerHTML = '<div class="text-center text-muted mt-5"><div class="spinner-border spinner-border-sm me-2"></div>Yorumlar Yükleniyor...</div>';

        const myUserId = getUserIdFromToken(token);

        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/${taskId}/comments`, {
        headers: { 'Authorization': `Bearer ${token}` }
        });

        if (response.ok) {
        const comments = await response.json();
        commentsList.innerHTML = '';

        if (comments.length === 0) {
        commentsList.innerHTML = `
        <div class="text-center text-muted mt-5" id="noCommentText" style="font-size: 0.9rem;">
        <i class="bi bi-chat-square-dots fs-1 mb-2 d-block opacity-50"></i>
        Henüz yorum yapılmamış.
        </div>`;
        return;
        }

        comments.forEach(c => {
        let deleteButtonHtml = '';
        if (c.userId === myUserId) {
        deleteButtonHtml = `
        <i class="bi bi-trash3 text-muted ms-2"
        style="cursor: pointer; transition: color 0.2s;"
        onmouseover="this.classList.remove('text-muted'); this.classList.add('text-danger');"
        onmouseout="this.classList.remove('text-danger'); this.classList.add('text-muted');"
        onclick="deleteTaskComment(${c.id})"
        title="Yorumu Sil"></i>
        `;
        }

        const commentHtml = `
        <div class="comment-item mb-3 p-3 rounded-3" style="background-color: var(--input-bg); border: 1px solid var(--input-border); animation: fadeIn 0.3s ease;">
        <div class="d-flex justify-content-between align-items-start mb-2">
        <div>
        <strong style="color: var(--text-main); font-size: 0.9rem;">${c.userName}</strong>
        <small class="text-muted ms-2" style="font-size: 0.75rem;">${c.createdAt}</small>
        </div>
        ${deleteButtonHtml}
        </div>
        <p class="m-0" style="color: var(--text-main); font-size: 0.95rem;">${c.text}</p>
        </div>`;
        commentsList.insertAdjacentHTML('beforeend', commentHtml);
        });

        commentsList.scrollTop = commentsList.scrollHeight;
        }
        } catch (error) {
        commentsList.innerHTML = '<div class="text-center text-danger mt-5">Yorumlar yüklenirken bir hata oluştu.</div>';
        }
        }

        function openTaskModal(taskId) {
        const task = globalTasksData.find(t => t.id === taskId);
        if (!task) return;

        document.getElementById('currentOpenTaskId').value = taskId;
        document.getElementById('taskDetailModalLabel').innerHTML = `<i class="bi bi-card-checklist me-2"></i>${task.title}`;

        quillEditor.root.innerHTML = task.description || '';

        const badge = document.getElementById('taskStatusBadge');
        badge.innerText = task.status;
        badge.className = `badge text-dark px-3 py-2 bg-${task.status === 'Done' ? 'success' : 'warning'}`;

        loadTaskComments(taskId);

        const modal = new bootstrap.Modal(document.getElementById('taskDetailModal'));
        modal.show();
        }

        async function saveTaskDescription() {
        const taskId = document.getElementById('currentOpenTaskId').value;
        const newDescription = quillEditor.root.innerHTML.trim();

        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/${taskId}/description`, {
        method: 'PUT',
        headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ description: newDescription })
        });

        if (response.ok) {
        Swal.fire({ icon: 'success', title: 'Açıklama kaydedildi', toast: true, position: 'top-end', showConfirmButton: false, timer: 1500 });
        loadTasks();
        } else {
        Swal.fire('Hata', 'Açıklama kaydedilemedi.', 'error');
        }
        } catch (error) { console.error("Kaydetme hatası:", error); }
        }

        async function addComment() {
        const taskId = document.getElementById('currentOpenTaskId').value;
        const input = document.getElementById('newCommentInput');
        const commentText = input.value.trim();

        if (!commentText || !taskId) return;

        input.disabled = true;

        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/${taskId}/comments`, {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ text: commentText })
        });

        if (response.ok) {
        const newComment = await response.json();

        const commentsList = document.getElementById('commentsList');
        const noCommentText = document.getElementById('noCommentText');
        if (noCommentText) noCommentText.style.display = 'none';

        const myUserId = getUserIdFromToken(token);
        let deleteButtonHtml = '';
        if (newComment.userId === myUserId) {
        deleteButtonHtml = `
        <i class="bi bi-trash3 text-muted ms-2"
        style="cursor: pointer; transition: color 0.2s;"
        onmouseover="this.classList.remove('text-muted'); this.classList.add('text-danger');"
        onmouseout="this.classList.remove('text-danger'); this.classList.add('text-muted');"
        onclick="deleteTaskComment(${newComment.id})"
        title="Yorumu Sil"></i>
        `;
        }

        const commentHtml = `
        <div class="comment-item mb-3 p-3 rounded-3" style="background-color: var(--input-bg); border: 1px solid var(--input-border); animation: fadeIn 0.3s ease;">
        <div class="d-flex justify-content-between align-items-start mb-2">
        <div>
        <strong style="color: var(--text-main); font-size: 0.9rem;">${newComment.userName}</strong>
        <small class="text-muted ms-2" style="font-size: 0.75rem;">${newComment.createdAt}</small>
        </div>
        ${deleteButtonHtml}
        </div>
        <p class="m-0" style="color: var(--text-main); font-size: 0.95rem;">${newComment.text}</p>
        </div>`;

        commentsList.insertAdjacentHTML('beforeend', commentHtml);
        input.value = '';
        commentsList.scrollTop = commentsList.scrollHeight;
        } else {
        Swal.fire('Hata', 'Yorum gönderilirken bir sorun oluştu.', 'error');
        }
        } catch (error) {
        console.error("Yorum gönderme hatası:", error);
        Swal.fire('Bağlantı Hatası', 'Sunucuya ulaşılamadı.', 'error');
        } finally {
        input.disabled = false;
        input.focus();
        }
        }

        async function deleteTaskComment(commentId) {
        const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';

        const result = await Swal.fire({
        title: 'Yorum Silinecek!',
        text: "Bu yorumu silmek istediğinize emin misiniz?",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Evet, Sil',
        cancelButtonText: 'İptal',
        background: isDark ? '#1e1e1e' : '#fff',
        color: isDark ? '#fff' : '#000',
        customClass: { confirmButton: 'btn btn-danger px-4 me-2', cancelButton: 'btn btn-secondary px-4' },
        buttonsStyling: false
        });

        if (result.isConfirmed) {
        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/comments/${commentId}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` }
        });

        if (response.ok) {
        const currentTaskId = document.getElementById('currentOpenTaskId').value;
        loadTaskComments(currentTaskId);
        } else {
        const err = await response.json();
        Swal.fire('Hata', err.message || 'Yorum silnemedi.', 'error');
        }
        } catch (error) {
        console.error("Yorum silme hatası:", error);
        }
        }
        }
    </script>
}