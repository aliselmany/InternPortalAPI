@{
    ViewData["Title"] = "Personel Paneli - Kanban";
    ViewData["HideNavbar"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/staff-portal.css" asp-append-version="true" />
    <style>
        body, html {
            height: 100vh !important;
            overflow: hidden !important;
            margin: 0;
            padding: 0;
        }

        .board-wrapper {
            height: calc(100vh - 85px);
            margin-top: 85px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            width: 133.33vw;
        }

        .kanban-canvas {
            flex-grow: 1;
            display: flex;
            align-items: flex-start;
            padding: 2rem 4rem;
            gap: 2rem;
            overflow-x: auto;
            overflow-y: hidden;
        }

        .kanban-col {
            min-width: 320px;
            max-width: 320px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            max-height: calc(100vh - 150px);
            border-width: 1px;
            border-style: solid;
            background: var(--card-bg);
            border-color: var(--input-border);
            box-shadow: 0 4px 6px var(--shadow);
            height: auto;
        }

        .kanban-col-header {
            padding: 1.2rem;
            font-weight: bold;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-shrink: 0;
            color: var(--text-main);
            border-bottom: 1px solid var(--input-border);
        }

        .kanban-cards {
            padding: 0.8rem;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
            min-height: 40px;
        }

            .kanban-cards::-webkit-scrollbar {
                width: 6px;
            }

            .kanban-cards::-webkit-scrollbar-track {
                background: transparent;
            }

            .kanban-cards::-webkit-scrollbar-thumb {
                background-color: var(--input-border);
                border-radius: 10px;
            }

        .kanban-card {
            padding: 1.2rem;
            border-radius: 8px;
            cursor: grab;
            position: relative;
            flex-shrink: 0;
            background: var(--input-bg);
            border: 1px solid var(--input-border);
            color: var(--text-main);
            box-shadow: 0 1px 3px var(--shadow);
            transition: transform 0.2s, border-color 0.2s;
        }

            .kanban-card:active {
                cursor: grabbing;
            }

            .kanban-card:hover {
                transform: translateY(-2px);
                border-color: var(--text-muted);
            }

        .delete-task-btn {
            position: absolute;
            top: 10px;
            right: 10px;
            opacity: 0;
            transition: all 0.2s;
            cursor: pointer;
            font-size: 1rem;
            color: var(--text-muted);
        }

        .kanban-card:hover .delete-task-btn {
            opacity: 1;
        }

        .delete-task-btn:hover {
            color: #ff4444 !important;
            transform: scale(1.1);
        }

        .add-card-btn {
            margin: 0.8rem;
            padding: 0.8rem;
            background: transparent;
            border: 1px dashed var(--input-border);
            text-align: center;
            border-radius: 8px;
            cursor: pointer;
            flex-shrink: 0;
            font-weight: 600;
            color: var(--text-muted);
            transition: all 0.2s;
        }

            .add-card-btn:hover {
                background: var(--input-bg);
                color: var(--text-main);
                border-color: var(--text-muted);
            }

        [data-bs-theme="dark"] .kanban-col {
            background: #212529;
        }

        [data-bs-theme="dark"] .kanban-card {
            background: #2b3035;
        }

        .custom-task-modal .modal-dialog {
            max-width: 55% !important;
            margin-top: 5rem;
        }

        .custom-task-modal .modal-content {
            background-color: var(--card-bg) !important;
            color: var(--text-main) !important;
            border: 1px solid var(--input-border) !important;
            border-radius: 16px !important;
            box-shadow: 0 15px 35px var(--shadow) !important;
        }

        .custom-task-modal .modal-header {
            border-bottom: 1px solid var(--input-border) !important;
            padding: 1.5rem 2rem !important;
        }

        .custom-task-modal .modal-body {
            padding: 2rem !important;
        }

        .custom-task-modal .form-control {
            background-color: var(--input-bg) !important;
            color: var(--text-main) !important;
            border: 2px solid var(--input-border) !important;
            border-radius: 12px !important;
            font-size: 1.15rem !important;
            padding: 1.5rem !important;
            resize: none !important;
        }

            .custom-task-modal .form-control:focus {
                border-color: #adb5bd !important;
                box-shadow: none !important;
            }

        [data-bs-theme="dark"] .custom-task-modal .btn-close {
            filter: invert(1) grayscale(100%) brightness(200%);
        }

        .modal-backdrop {
            width: 133.33vw !important;
            height: 133.33vh !important;
        }

        .modal {
            width: 133.33vw !important;
            height: 133.33vh !important;
        }

        .btn-theme-custom {
            background-color: var(--btn-bg) !important;
            color: var(--btn-text) !important;
            border: 1px solid var(--input-border) !important;
        }

            .btn-theme-custom:hover {
                opacity: 0.85;
            }

        .inline-add-input {
            background-color: var(--input-bg) !important;
            color: var(--text-main) !important;
            border: 1px solid var(--input-border) !important;
            border-radius: 8px !important;
            resize: none !important;
            font-size: 0.95rem !important;
            padding: 0.8rem !important;
        }

            .inline-add-input:focus {
                background-color: var(--card-bg) !important;
                border-color: var(--text-muted) !important;
                box-shadow: none !important;
            }

        .close-add-form {
            cursor: pointer;
            transition: color 0.2s;
        }

            .close-add-form:hover {
                color: var(--text-main) !important;
            }

        .add-card-form {
            padding: 0 0.8rem 0.8rem 0.8rem;
        }
    </style>
}

<partial name="_StaffNavbarPartial" />

<div class="board-wrapper">
    <div class="kanban-canvas" id="kanbanBoard">
        <div class="kanban-col">
            <div class="kanban-col-header"><span>Yapılacaklar</span><i class="bi bi-three-dots"></i></div>
            <div class="kanban-cards" id="ToDo" data-status="ToDo"></div>

            <div class="add-card-form" id="addForm-ToDo" style="display: none;">
                <textarea class="form-control mb-2 inline-add-input shadow-none" id="input-ToDo" rows="2" placeholder="Bir başlık girin..."></textarea>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-theme-custom btn-sm px-3 fw-bold" onclick="submitNewTask('ToDo')">Kart Ekle</button>
                    <i class="bi bi-x-lg fs-5 text-muted close-add-form" onclick="hideAddCardForm('ToDo')"></i>
                </div>
            </div>
            <button class="add-card-btn" id="addBtn-ToDo" onclick="showAddCardForm('ToDo')"><i class="bi bi-plus-lg me-1"></i> Kart ekle</button>
        </div>

        <div class="kanban-col">
            <div class="kanban-col-header"><span>Yapılıyor</span><i class="bi bi-three-dots"></i></div>
            <div class="kanban-cards" id="InProgress" data-status="InProgress"></div>

            <div class="add-card-form" id="addForm-InProgress" style="display: none;">
                <textarea class="form-control mb-2 inline-add-input shadow-none" id="input-InProgress" rows="2" placeholder="Bir başlık girin..."></textarea>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-theme-custom btn-sm px-3 fw-bold" onclick="submitNewTask('InProgress')">Kart Ekle</button>
                    <i class="bi bi-x-lg fs-5 text-muted close-add-form" onclick="hideAddCardForm('InProgress')"></i>
                </div>
            </div>
            <button class="add-card-btn" id="addBtn-InProgress" onclick="showAddCardForm('InProgress')"><i class="bi bi-plus-lg me-1"></i> Kart ekle</button>
        </div>

        <div class="kanban-col">
            <div class="kanban-col-header"><span>İnceleniyor</span><i class="bi bi-three-dots"></i></div>
            <div class="kanban-cards" id="InReview" data-status="InReview"></div>

            <div class="add-card-form" id="addForm-InReview" style="display: none;">
                <textarea class="form-control mb-2 inline-add-input shadow-none" id="input-InReview" rows="2" placeholder="Bir başlık girin..."></textarea>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-theme-custom btn-sm px-3 fw-bold" onclick="submitNewTask('InReview')">Kart Ekle</button>
                    <i class="bi bi-x-lg fs-5 text-muted close-add-form" onclick="hideAddCardForm('InReview')"></i>
                </div>
            </div>
            <button class="add-card-btn" id="addBtn-InReview" onclick="showAddCardForm('InReview')"><i class="bi bi-plus-lg me-1"></i> Kart ekle</button>
        </div>

        <div class="kanban-col">
            <div class="kanban-col-header"><span>Tamamlandı</span><i class="bi bi-three-dots"></i></div>
            <div class="kanban-cards" id="Done" data-status="Done"></div>

            <div class="add-card-form" id="addForm-Done" style="display: none;">
                <textarea class="form-control mb-2 inline-add-input shadow-none" id="input-Done" rows="2" placeholder="Bir başlık girin..."></textarea>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-theme-custom btn-sm px-3 fw-bold" onclick="submitNewTask('Done')">Kart Ekle</button>
                    <i class="bi bi-x-lg fs-5 text-muted close-add-form" onclick="hideAddCardForm('Done')"></i>
                </div>
            </div>
            <button class="add-card-btn" id="addBtn-Done" onclick="showAddCardForm('Done')"><i class="bi bi-plus-lg me-1"></i> Kart ekle</button>
        </div>
    </div>
</div>

<div class="modal fade custom-task-modal" id="taskDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title fw-bold m-0" id="taskDetailModalLabel">
                    <i class="bi bi-card-checklist me-2"></i>Görev Adı
                </h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="text-uppercase text-muted fw-bold m-0" style="letter-spacing: 1px;"><i class="bi bi-justify-left me-2"></i>Açıklama</h5>
                    <span id="taskStatusBadge" class="badge bg-warning text-dark px-4 py-2 fs-6" style="border-radius: 8px;">ToDo</span>
                </div>
                <textarea id="taskDescriptionInput" class="form-control mb-4" rows="8" placeholder="Bu görev için detaylı bir açıklama girin..."></textarea>
                <div class="d-flex justify-content-end">
                    <button class="btn btn-theme-custom px-5 py-3 fw-bold fs-5" onclick="saveTaskDescription()" style="border-radius: 10px;">
                        <i class="bi bi-save me-2"></i> Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade custom-task-modal" id="transferModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog" style="max-width: 45% !important;">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title fw-bold m-0" style="color: var(--text-main);">
                    <i class="bi bi-arrow-left-right me-2"></i>Stajyeri Başka Mentöre Devret
                </h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="fs-5 text-muted mb-4">Seçili stajyeri kendi sorumluluğunuzdan çıkarıp başka bir personele (mentöre) devretmek için aşağıdan seçim yapın.</p>
                <label class="form-label text-muted fw-bold text-uppercase" style="letter-spacing: 1px;">Yeni Mentör Seçin:</label>
                <select id="mentorSelect" class="form-select mb-4 shadow-sm" style="padding: 1rem !important; font-size: 1rem !important; background-color: var(--input-bg); color: var(--text-main); border: 2px solid var(--input-border); border-radius: 12px;">
                    <option value="">Yükleniyor...</option>
                </select>
                <div class="d-flex justify-content-end mt-2">
                    <button class="btn btn-theme-custom px-5 py-3 fw-bold fs-5 rounded-3" onclick="executeTransfer()">
                        Devret
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="currentOpenTaskId" value="" />

@section Scripts {
    <partial name="_ThemeScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>

    <script>
        const token = localStorage.getItem('token');
        if (!token) window.location.replace('/Account/Login');

        const API_URL = "https://localhost:7166";

        let globalTasksData = [];
        let globalInternsList = [];

        function getUserIdFromToken(jwt) {
        try {
        const payload = JSON.parse(atob(jwt.split('.')[1]));
        return payload["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier"];
        } catch (e) { return null; }
        }

        const currentStaffId = getUserIdFromToken(token);
        const urlParams = new URLSearchParams(window.location.search);
        let currentInternId = urlParams.get('internId');

        document.addEventListener('DOMContentLoaded', () => {
        initSortable();
        loadInternData();
        });

        async function loadInternData() {
        if (!currentStaffId) return;

        try {
        const response = await fetch(`${API_URL}/api/Users/my-interns/${currentStaffId}`, {
        headers: { 'Authorization': `Bearer ${token}` }
        });

        if (response.ok) {
        const interns = await response.json();
        globalInternsList = interns;
        const navDisplay = document.getElementById('navbarInternNameDisplay');

        if (interns.length === 0) {
        if(navDisplay) navDisplay.innerHTML = `<i class="bi bi-person-workspace text-secondary me-2"></i> Stajyer Bulunmuyor`;
        return;
        }

        if (!currentInternId && interns.length > 0) {
        currentInternId = interns[0].id;
        }

        const activeIntern = interns.find(i => i.id === currentInternId);
        if (activeIntern && navDisplay) {
        const displayName = activeIntern.fullName || (activeIntern.name + " " + activeIntern.surname);
        navDisplay.innerHTML = `<i class="bi bi-person-workspace text-secondary me-2"></i> ${displayName} <span class="text-muted fw-normal ms-1" style="font-size: 0.9rem;">(Çalışma Alanı)</span>`;
        }

        if (currentInternId) loadTasks();
        }
        } catch (error) { console.error("Stajyer bilgileri yüklenemedi:", error); }
        }

        window.openTransferModal = async function() {
        if (!currentInternId) return;

        const modal = new bootstrap.Modal(document.getElementById('transferModal'));
        modal.show();

        const select = document.getElementById('mentorSelect');
        select.innerHTML = '<option value="">Mentörler aranıyor...</option>';

        try {
        const response = await fetch(`${API_URL}/api/Users/available-mentors`, {
        headers: { 'Authorization': `Bearer ${token}` }
        });

        if (response.ok) {
        const mentors = await response.json();
        select.innerHTML = '<option value="">Listeden bir mentör seçin...</option>';
        mentors.forEach(m => {
        if(m.id !== currentStaffId) {
        select.innerHTML += `<option value="${m.id}">${m.fullName} (Doluluk: ${m.currentCount}/${m.maxCapacity})</option>`;
        }
        });
        } else {
        select.innerHTML = '<option value="">Mentör listesi çekilemedi.</option>';
        }
        } catch (error) {
        select.innerHTML = '<option value="">Bir hata oluştu.</option>';
        }
        }

        async function executeTransfer() {
        const mentorId = document.getElementById('mentorSelect').value;
        if (!mentorId) {
        Swal.fire('Eksik Seçim', 'Lütfen devredeceğiniz personeli seçin.', 'warning');
        return;
        }

        const activeIntern = globalInternsList.find(i => i.id === currentInternId);
        const internName = activeIntern ? (activeIntern.fullName || activeIntern.name + " " + activeIntern.surname) : "Seçili Stajyer";
        const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';

        const result = await Swal.fire({
        title: 'Emin misiniz?',
        text: `${internName} isimli stajyeri devretmek üzeresiniz.`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Evet, Devret',
        cancelButtonText: 'İptal',
        background: isDark ? '#1e1e1e' : '#fff',
        color: isDark ? '#fff' : '#000',
        customClass: {
        confirmButton: 'btn btn-theme-custom px-4 me-2',
        cancelButton: 'btn btn-secondary px-4'
        },
        buttonsStyling: false
        });

        if (result.isConfirmed) {
        try {
        const response = await fetch(`${API_URL}/api/Users/assign-mentor`, {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ internId: currentInternId, mentorId: mentorId })
        });

        if (response.ok) {
        bootstrap.Modal.getInstance(document.getElementById('transferModal')).hide();
        Swal.fire({ icon: 'success', title: 'Başarıyla Devredildi', showConfirmButton: false, timer: 2000 });

        currentInternId = null;
        document.getElementById('kanbanBoard').innerHTML = '';
        const navDisplay = document.getElementById('navbarInternNameDisplay');
        if(navDisplay) navDisplay.innerHTML = `<i class="bi bi-person-workspace text-secondary me-2"></i> Stajyer Seçilmedi`;

        setTimeout(() => {
        window.location.href = '/Staff/StaffDashboardIndex';
        }, 1500);

        } else {
        const err = await response.json();
        Swal.fire('Hata', err.message || 'Devir işlemi başarısız oldu.', 'error');
        }
        } catch (error) { console.error(error); }
        }
        }

        async function loadTasks() {
        if (!currentInternId) return;
        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/intern/${currentInternId}`, {
        headers: { 'Authorization': `Bearer ${token}` }
        });

        if (response.ok) {
        const tasks = await response.json();
        globalTasksData = tasks;

        ['ToDo', 'InProgress', 'InReview', 'Done'].forEach(id => document.getElementById(id).innerHTML = '');

        tasks.forEach(task => {
        const cardHtml = `
        <div class="kanban-card shadow-sm" data-task-id="${task.id}" onclick="openTaskModal(${task.id})">
        ${task.title}
        <i class="bi bi-trash3 delete-task-btn" onclick="event.stopPropagation(); deleteTask(${task.id})"></i>
        </div>`;
        document.getElementById(task.status).insertAdjacentHTML('beforeend', cardHtml);
        });
        }
        } catch (error) { console.error("Görev yükleme hatası:", error); }
        }

        function showAddCardForm(status) {
        document.getElementById(`addBtn-${status}`).style.display = 'none';
        document.getElementById(`addForm-${status}`).style.display = 'block';
        const inputElement = document.getElementById(`input-${status}`);
        inputElement.focus();
        inputElement.onkeydown = function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        submitNewTask(status);
        }
        };
        }

        function hideAddCardForm(status) {
        document.getElementById(`addForm-${status}`).style.display = 'none';
        document.getElementById(`input-${status}`).value = '';
        document.getElementById(`addBtn-${status}`).style.display = 'block';
        }

        async function submitNewTask(status) {
        if (!currentInternId || !currentStaffId) return;
        const inputElement = document.getElementById(`input-${status}`);
        const taskTitle = inputElement.value.trim();
        if (!taskTitle) { inputElement.focus(); return; }

        const newTask = { title: taskTitle, internId: currentInternId, staffId: currentStaffId, status: status };
        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify(newTask)
        });

        if (response.ok) {
        hideAddCardForm(status);
        loadTasks();
        } else {
        const err = await response.json();
        Swal.fire('Hata', err.message || 'Görev eklenirken bir sorun oluştu.', 'error');
        }
        } catch (error) { console.error("Ekleme hatası:", error); }
        }

        async function deleteTask(taskId) {
        const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
        const result = await Swal.fire({
        title: 'Silinsin mi?',
        text: "Bu görev kalıcı olarak silinecek!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Sil',
        cancelButtonText: 'Vazgeç',
        background: isDark ? '#1e1e1e' : '#fff',
        color: isDark ? '#fff' : '#000',
        customClass: { confirmButton: 'btn btn-danger px-4 me-2', cancelButton: 'btn btn-secondary px-4' },
        buttonsStyling: false
        });

        if (result.isConfirmed) {
        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/${taskId}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` }
        });
        if (response.ok) {
        loadTasks();
        Swal.fire({ icon: 'success', title: 'Silindi', toast: true, position: 'top-end', showConfirmButton: false, timer: 1500 });
        }
        } catch (error) { console.error("Silme hatası:", error); }
        }
        }

        function initSortable() {
        ['ToDo', 'InProgress', 'InReview', 'Done'].forEach(colId => {
        const el = document.getElementById(colId);
        if (el) {
        new Sortable(el, {
        group: 'kanban',
        animation: 150,
        ghostClass: 'bg-secondary',
        onEnd: function (evt) {
        const taskId = evt.item.getAttribute('data-task-id');
        const newStatus = evt.to.getAttribute('data-status');
        const newOrderIndex = evt.newIndex;
        updateTaskPosition(taskId, newStatus, newOrderIndex);
        }
        });
        }
        });
        }

        async function updateTaskPosition(taskId, newStatus, newOrderIndex) {
        try {
        await fetch(`${API_URL}/api/KanbanTasks/move`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify({ taskId: parseInt(taskId), newStatus, newOrderIndex })
        });
        } catch (error) { loadTasks(); }
        }

        function openTaskModal(taskId) {
        const task = globalTasksData.find(t => t.id === taskId);
        if (!task) return;

        document.getElementById('currentOpenTaskId').value = taskId;
        document.getElementById('taskDetailModalLabel').innerHTML = `<i class="bi bi-card-checklist me-2"></i>${task.title}`;
        document.getElementById('taskDescriptionInput').value = task.description || '';

        const badge = document.getElementById('taskStatusBadge');
        badge.innerText = task.status;
        badge.className = `badge text-dark px-3 py-2 bg-${task.status === 'Done' ? 'success' : 'warning'}`;

        const modal = new bootstrap.Modal(document.getElementById('taskDetailModal'));
        modal.show();
        }

        async function saveTaskDescription() {
        const taskId = document.getElementById('currentOpenTaskId').value;
        const newDescription = document.getElementById('taskDescriptionInput').value.trim();

        try {
        const response = await fetch(`${API_URL}/api/KanbanTasks/${taskId}/description`, {
        method: 'PUT',
        headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ description: newDescription })
        });

        if (response.ok) {
        Swal.fire({ icon: 'success', title: 'Açıklama kaydedildi', toast: true, position: 'top-end', showConfirmButton: false, timer: 1500 });
        loadTasks();
        } else {
        Swal.fire('Hata', 'Açıklama kaydedilemedi.', 'error');
        }
        } catch (error) { console.error("Kaydetme hatası:", error); }
        }
    </script>
}