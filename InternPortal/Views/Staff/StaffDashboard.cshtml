@{
    ViewData["Title"] = "Personel Paneli - Kanban";
    ViewData["HideNavbar"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/staff-portal.css" asp-append-version="true" />
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

    <style>
        body, html {
            height: 100vh !important;
            overflow: hidden !important;
            margin: 0;
            padding: 0;
        }

        .board-wrapper {
            height: calc(100vh - 85px);
            margin-top: 85px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            width: 133.33vw;
        }

        .kanban-canvas {
            flex-grow: 1;
            display: flex;
            align-items: flex-start;
            padding: 2rem 4rem;
            gap: 2rem;
            overflow-x: auto;
            overflow-y: hidden;
        }

        .kanban-col {
            min-width: 340px;
            max-width: 340px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            max-height: calc(100vh - 150px);
            border-width: 1px;
            border-style: solid;
            background: var(--card-bg);
            border-color: var(--input-border);
            box-shadow: 0 4px 6px var(--shadow);
            height: auto;
        }

        .kanban-col-header {
            padding: 1.2rem;
            font-size: 1.15rem !important;
            font-weight: bold;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-shrink: 0;
            color: var(--text-main);
            border-bottom: 1px solid var(--input-border);
        }

        .kanban-cards {
            padding: 0.8rem;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
            min-height: 40px;
        }

            .kanban-cards::-webkit-scrollbar {
                width: 6px;
            }

            .kanban-cards::-webkit-scrollbar-track {
                background: transparent;
            }

            .kanban-cards::-webkit-scrollbar-thumb {
                background-color: var(--input-border);
                border-radius: 10px;
            }

        .kanban-card {
            padding: 1.2rem;
            border-radius: 8px;
            cursor: grab;
            position: relative;
            flex-shrink: 0;
            background: var(--input-bg);
            border: 1px solid var(--input-border);
            color: var(--text-main);
            font-size: 1.05rem !important;
            font-weight: 500 !important;
            box-shadow: 0 1px 3px var(--shadow);
            transition: transform 0.2s, border-color 0.2s;
        }

            .kanban-card:active {
                cursor: grabbing;
            }

            .kanban-card:hover {
                transform: translateY(-2px);
                border-color: var(--text-muted);
            }

        .delete-task-btn {
            position: absolute;
            top: 12px;
            right: 12px;
            opacity: 0;
            transition: all 0.2s;
            cursor: pointer;
            font-size: 1rem;
            color: var(--text-muted);
        }

        .kanban-card:hover .delete-task-btn {
            opacity: 1;
        }

        .delete-task-btn:hover {
            color: #ff4444 !important;
            transform: scale(1.1);
        }

        .add-card-btn {
            margin: 0.8rem;
            padding: 0.8rem;
            background: transparent;
            border: 1px dashed var(--input-border);
            text-align: center;
            border-radius: 8px;
            cursor: pointer;
            flex-shrink: 0;
            font-weight: 600;
            color: var(--text-muted);
            transition: all 0.2s;
        }

            .add-card-btn:hover {
                background: var(--input-bg);
                color: var(--text-main);
                border-color: var(--text-muted);
            }

        [data-bs-theme="dark"] .kanban-col {
            background: #212529;
        }

        [data-bs-theme="dark"] .kanban-card {
            background: #2b3035;
        }

        .custom-task-modal .modal-dialog {
            max-width: 65% !important;
            margin-top: 5rem;
        }

        .custom-task-modal .modal-content {
            background-color: var(--card-bg) !important;
            color: var(--text-main) !important;
            border: 1px solid var(--input-border) !important;
            border-radius: 16px !important;
            box-shadow: 0 15px 35px var(--shadow) !important;
        }

        .custom-task-modal .form-control {
            background-color: var(--input-bg) !important;
            color: var(--text-main) !important;
            border: 2px solid var(--input-border) !important;
            border-radius: 12px !important;
            font-size: 1.15rem !important;
            padding: 1.5rem !important;
            resize: none !important;
        }

            .custom-task-modal .form-control:focus {
                border-color: #adb5bd !important;
                box-shadow: none !important;
            }

        [data-bs-theme="dark"] .custom-task-modal .btn-close {
            filter: invert(1) grayscale(100%) brightness(200%);
        }

        .modal-backdrop {
            width: 133.33vw !important;
            height: 133.33vh !important;
        }

        .modal {
            width: 133.33vw !important;
            height: 133.33vh !important;
        }

        .btn-theme-custom {
            background-color: var(--btn-bg) !important;
            color: var(--btn-text) !important;
            border: 1px solid var(--input-border) !important;
        }

            .btn-theme-custom:hover {
                opacity: 0.85;
            }

        .inline-add-input {
            background-color: var(--input-bg) !important;
            color: var(--text-main) !important;
            border: 1px solid var(--input-border) !important;
            border-radius: 8px !important;
            resize: none !important;
            font-size: 0.95rem !important;
            padding: 0.8rem !important;
        }

            .inline-add-input:focus {
                background-color: var(--card-bg) !important;
                border-color: var(--text-muted) !important;
                box-shadow: none !important;
            }

        .close-add-form {
            cursor: pointer;
            transition: color 0.2s;
        }

            .close-add-form:hover {
                color: var(--text-main) !important;
            }

        .add-card-form {
            padding: 0 0.8rem 0.8rem 0.8rem;
        }

        .editor-wrapper {
            border: 2px solid var(--input-border);
            border-radius: 8px;
            background-color: var(--input-bg);
            transition: all 0.2s ease-in-out;
            overflow: hidden;
            margin-bottom: 1.5rem;
        }

            .editor-wrapper:focus-within {
                border-color: #3b82f6;
                box-shadow: 0 0 0 1px #3b82f6;
            }

        .ql-toolbar.ql-snow {
            border: none !important;
            border-bottom: 1px solid var(--input-border) !important;
            padding: 10px 15px !important;
            background-color: transparent;
        }

        .ql-container.ql-snow {
            border: none !important;
            font-size: 1.1rem;
            font-family: inherit;
            color: var(--text-main);
        }

        .ql-editor {
            min-height: 250px;
        }

            .ql-editor a, #taskDescriptionEditor a, .ql-container a {
                color: #3b82f6 !important;
                background-color: rgba(59, 130, 246, 0.15) !important;
                border: 1px solid rgba(59, 130, 246, 0.3) !important;
                padding: 4px 10px !important;
                border-radius: 6px !important;
                text-decoration: none !important;
                font-weight: 600 !important;
                display: inline-flex !important;
                align-items: center !important;
                gap: 6px !important;
                transition: all 0.2s ease-in-out !important;
                margin: 2px 4px !important;
            }

                .ql-editor a::before, #taskDescriptionEditor a::before, .ql-container a::before {
                    content: "🔗" !important;
                    font-size: 0.9rem !important;
                }

                .ql-editor a:hover, #taskDescriptionEditor a:hover, .ql-container a:hover {
                    color: #ffffff !important;
                    background-color: #3b82f6 !important;
                    border-color: #3b82f6 !important;
                    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4) !important;
                    transform: translateY(-1px) !important;
                }

        [data-bs-theme="dark"] .ql-snow .ql-stroke {
            stroke: #adb5bd;
        }

        [data-bs-theme="dark"] .ql-snow .ql-fill {
            fill: #adb5bd;
        }

        [data-bs-theme="dark"] .ql-snow .ql-picker {
            color: #adb5bd;
        }

        [data-bs-theme="dark"] .ql-editor.ql-blank::before {
            color: #6c757d;
            font-style: normal;
        }

        .comments-container::-webkit-scrollbar {
            width: 6px;
        }

        .comments-container::-webkit-scrollbar-track {
            background: transparent;
        }

        .comments-container::-webkit-scrollbar-thumb {
            background-color: var(--input-border);
            border-radius: 10px;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
}

<partial name="_StaffNavbarPartial" />

<div class="board-wrapper">
    <div class="kanban-canvas" id="kanbanBoard">
        <div class="kanban-col">
            <div class="kanban-col-header"><span>Yapılacaklar</span><i class="bi bi-three-dots"></i></div>
            <div class="kanban-cards" id="ToDo" data-status="ToDo"></div>

            <div class="add-card-form" id="addForm-ToDo" style="display: none;">
                <textarea class="form-control mb-2 inline-add-input shadow-none" id="input-ToDo" rows="2" placeholder="Bir başlık girin..."></textarea>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-theme-custom btn-sm px-3 fw-bold" onclick="submitNewTask('ToDo')">Kart Ekle</button>
                    <i class="bi bi-x-lg fs-5 text-muted close-add-form" onclick="hideAddCardForm('ToDo')"></i>
                </div>
            </div>
            <button class="add-card-btn" id="addBtn-ToDo" onclick="showAddCardForm('ToDo')"><i class="bi bi-plus-lg me-1"></i> Kart ekle</button>
        </div>

        <div class="kanban-col">
            <div class="kanban-col-header"><span>Yapılıyor</span><i class="bi bi-three-dots"></i></div>
            <div class="kanban-cards" id="InProgress" data-status="InProgress"></div>

            <div class="add-card-form" id="addForm-InProgress" style="display: none;">
