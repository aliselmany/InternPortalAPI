                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-theme-custom btn-sm px-3 fw-bold" onclick="submitNewTask('Done')">Kart Ekle</button>
                    <i class="bi bi-x-lg fs-5 text-muted close-add-form" onclick="hideAddCardForm('Done')"></i>
