@{
    ViewData["Title"] = "Çalışma Alanı";
    ViewData["HideNavbar"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/staff-portal.css" asp-append-version="true" />
    <style>

        body, html {
            height: auto !important;
            min-height: 100vh !important;
            overflow-y: auto !important;
            overflow-x: hidden !important;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .workspace-section {
            padding: 3rem 5rem;
            max-width: 1400px;
            margin: 0 auto;
            padding-bottom: 5rem;
        }

        .board-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 25px;
            margin-top: 2rem;
        }

        .intern-board-card {
            border-radius: 12px;
            height: 140px;
            padding: 20px;
            font-weight: 600;
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

          
            .intern-board-card .kanban-icon {
                font-size: 1.8rem;
                opacity: 0.3;
                transition: opacity 0.3s;
            }

            .intern-board-card:hover {
                transform: translateY(-8px);
                border-color: var(--text-main) !important;
            }

                .intern-board-card:hover .kanban-icon {
                    opacity: 1;
                    color: var(--text-main) !important;
                }

      
        .time-badge {
            font-size: 0.8rem;
            padding: 6px 12px;
            border-radius: 8px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            background-color: rgba(108, 117, 125, 0.1);
            border: 1px solid rgba(108, 117, 125, 0.2);
            transition: all 0.3s ease;
        }

        .section-title {
            letter-spacing: 1px;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        .placeholder-card {
            border-radius: 12px;
            height: 140px;
            padding: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            cursor: default;
            border-style: dashed;
            border-width: 2px;
        }

        [data-bs-theme="dark"] body,
        [data-bs-theme="dark"] html {
            background-color: #1a1d20;
            color: #f8f9fa;
        }

        [data-bs-theme="dark"] .intern-board-card {
            background: linear-gradient(135deg, #2b3035 0%, #1a1d20 100%);
            border: 1px solid rgba(255,255,255,0.1);
            color: #ffffff;
            box-shadow: 0 4px 6px rgba(0,0,0,0.2);
        }

            [data-bs-theme="dark"] .intern-board-card:hover {
                box-shadow: 0 10px 20px rgba(0,0,0,0.4);
            }

            [data-bs-theme="dark"] .intern-board-card .kanban-icon {
                color: #ffffff;
            }

        [data-bs-theme="dark"] .section-title {
            color: #f8f9fa;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        [data-bs-theme="dark"] .placeholder-card {
            background: transparent;
            border-color: rgba(255,255,255,0.2);
        }

            [data-bs-theme="dark"] .placeholder-card span {
                color: #adb5bd !important;
            }

        [data-bs-theme="dark"] .time-badge {
            color: #adb5bd;
        }


        [data-bs-theme="light"] body,
        [data-bs-theme="light"] html {
            background-color: #f8f9fa;
            color: #212529;
        }

        [data-bs-theme="light"] .intern-board-card {
            background: #ffffff;
            border: 1px solid #dee2e6;
            color: #212529;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

            [data-bs-theme="light"] .intern-board-card:hover {
                box-shadow: 0 10px 20px rgba(0,0,0,0.15);
            }

            [data-bs-theme="light"] .intern-board-card .kanban-icon {
                color: #212529;
            }

        [data-bs-theme="light"] .section-title {
            color: #212529;
            border-bottom: 1px solid #dee2e6;
        }

        [data-bs-theme="light"] .placeholder-card {
            background: transparent;
            border-color: #ced4da;
        }

            [data-bs-theme="light"] .placeholder-card span {
                color: #6c757d !important;
            }

        [data-bs-theme="light"] .time-badge {
            color: #6c757d;
        }
    </style>
}

<partial name="_StaffNavbarPartial" />

<div class="workspace-section">
    <h3 class="section-title">
        <i class="bi bi-collection-play me-2"></i> Çalışma Alanlarınız
    </h3>

    <div class="board-grid" id="internBoardsContainer">
        <div class="placeholder-card" id="placeholderCard">
            <span class="text-secondary small fw-bold">Yeni stajyer eklendiğinde<br>burada görünecektir</span>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ThemeScriptsPartial" />
    <script>
        const API_URL = "https://localhost:7166";
        const token = localStorage.getItem('token');

        if (!token) window.location.replace('/Account/Login');

        function getUserIdFromToken(jwt) {
            try {
                const payload = JSON.parse(atob(jwt.split('.')[1]));
                return payload["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier"];
            } catch (e) {
                return null;
            }
        }

        const currentStaffId = getUserIdFromToken(token);

        document.addEventListener('DOMContentLoaded', loadInternBoards);

       
        function calculateRemainingTime(endDateString) {
            if (!endDateString) return "Süre belirsiz";

            const endDate = new Date(endDateString);
            const today = new Date();

            today.setHours(0, 0, 0, 0);
            endDate.setHours(0, 0, 0, 0);

            if (endDate < today) return "Staj bitti";

            let months = endDate.getMonth() - today.getMonth() + (12 * (endDate.getFullYear() - today.getFullYear()));
            let days = endDate.getDate() - today.getDate();

            if (days < 0) {
                months--;
                const previousMonth = new Date(endDate.getFullYear(), endDate.getMonth(), 0).getDate();
                days += previousMonth;
            }

            if (months === 0 && days === 0) return "Son gün";

            let result = "";
            if (months > 0) result += `${months} ay `;
            if (days > 0) result += `${days} gün `;

            return result.trim() + " kaldı";
        }

        async function loadInternBoards() {
            if (!currentStaffId) return;

            try {
                const response = await fetch(`${API_URL}/api/Users/my-interns/${currentStaffId}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (response.ok) {
                    const interns = await response.json();
                    const placeholder = document.getElementById('placeholderCard');

                    interns.forEach(intern => {
                        const displayName = intern.fullName || (intern.name + " " + intern.surname);

                        const remainingTime = calculateRemainingTime(intern.endDate || intern.internshipEndDate);

                        const cardHtml = `
                            <div class="intern-board-card" onclick="goToBoard('${intern.id}')">
                                <span>${displayName}</span>
                                <div class="d-flex justify-content-between align-items-end w-100">
                                    <span class="time-badge shadow-sm"><i class="bi bi-hourglass-split me-1"></i>${remainingTime}</span>
                                    <i class="bi bi-kanban kanban-icon mb-1"></i>
                                </div>
                            </div>`;

                        placeholder.insertAdjacentHTML('beforebegin', cardHtml);
                    });
                }
            } catch (error) {
                console.error("Boardlar yüklenemedi:", error);s
            }
        }

        function goToBoard(internId) {
            window.location.href = `/Staff/StaffDashboard?internId=${internId}`;
        }
    </script>
}